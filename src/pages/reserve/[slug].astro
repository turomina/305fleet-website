---
// W2: Wheelbase reservation page — Variant B via <listing-details>
// Route: /reserve/[public-vehicle-slug]/ — English only, noindex, excluded from sitemap
// This is the production-candidate transactional handoff from native vehicle pages.

import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/base/Header.astro";
import Footer from "../../components/base/Footer.astro";
import { getFuelLabel } from "../../config/labels";
import {
  DEALER_ID,
  WHEELBASE_RENTAL_IDS,
  getWheelbaseVehicles,
} from "../../data/wheelbase-mapping";

export function getStaticPaths() {
  return getWheelbaseVehicles().map((v) => ({
    params: { slug: v.slug },
  }));
}

const { slug } = Astro.params;
const vehicle = getWheelbaseVehicles().find((v) => v.slug === slug);
const wbId = vehicle ? WHEELBASE_RENTAL_IDS[vehicle.slug as keyof typeof WHEELBASE_RENTAL_IDS] : null;
---

<BaseLayout
  title={vehicle ? `${vehicle.name} — Availability & Pricing` : "Vehicle Not Found"}
  description={vehicle ? `Check real-time availability for the ${vehicle.name}. Pricing, dates, and protection from 305 Fleet.` : ""}
  noindex={true}
  hideSpanishHreflang={true}
>
  <Header />

  <main id="main-content" class="flex-1">
    {!vehicle || !wbId ? (
      <section class="section bg-surface">
        <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 text-center py-16">
          <h1 class="text-2xl font-bold text-ink">Vehicle not available</h1>
          <p class="mt-2 text-ink-secondary">This vehicle is not currently available for online booking.</p>
          <a href="/vehicles/" class="btn btn-primary mt-6">Browse Fleet</a>
        </div>
      </section>
    ) : (
      <>
        <!-- Native vehicle header -->
        <section class="bg-navy-900 text-white section-sm">
          <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
            <a
              href={`/vehicles/${vehicle.slug}/`}
              class="inline-flex items-center gap-1 text-sm text-white/60 hover:text-white/90 mb-3 transition-colors"
            >
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>
              Back to {vehicle.name}
            </a>
            <h1 class="text-2xl sm:text-3xl lg:text-4xl font-bold tracking-tight">{vehicle.name}</h1>
            <p class="mt-2 text-white/70 text-sm sm:text-base">{vehicle.tagline_en}</p>
            <div class="mt-3 flex flex-wrap items-center gap-3 text-sm text-white/50">
              <span class="inline-flex items-center gap-1">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a4 4 0 00-3-3.87M9 20H4v-2a4 4 0 013-3.87m6-5.13a4 4 0 11-8 0 4 4 0 018 0zm6 0a4 4 0 11-8 0 4 4 0 018 0z"/></svg>
                {vehicle.passenger_capacity} passengers
              </span>
              <span class="inline-flex items-center gap-1">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg>
                {vehicle.luggage_large} large bags
              </span>
              <span>{getFuelLabel(vehicle.fuel_type, "en")}</span>
            </div>
          </div>
        </section>

        <!-- Wheelbase listing-details -->
        <section class="bg-surface section">
          <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
            <!-- Delivery notice — concise, single line on desktop -->
            <div class="mb-6 p-3 sm:p-4 bg-brand-50 border border-brand-100 rounded-lg">
              <p class="text-xs sm:text-sm text-ink-secondary leading-relaxed">
                <strong class="text-ink">Pickup &amp; delivery:</strong> Free pickup in Pembroke Pines. Free delivery to MIA &amp; FLL. Paid delivery available to PBI and the local service area. Airport parking charges are the guest&rsquo;s responsibility. Special delivery is subject to confirmation.
              </p>
            </div>

            <!-- Loading state -->
            <div id="wb-loading" class="py-16 text-center">
              <div class="inline-block w-8 h-8 border-3 border-brand-200 border-t-brand rounded-full animate-spin mb-4"></div>
              <p class="text-ink-secondary">Loading availability&hellip;</p>
            </div>

            <!-- Error state -->
            <div id="wb-error" class="hidden py-16 text-center">
              <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-accent-50 mb-4">
                <svg class="w-8 h-8 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
              </div>
              <h3 class="text-xl font-semibold text-ink mb-2">Booking system unavailable</h3>
              <p class="text-ink-secondary max-w-md mx-auto mb-6">
                We&rsquo;re having trouble loading our booking system. Please try again or <a href="/contact/" class="text-brand underline">contact us</a> for availability.
              </p>
              <button type="button" id="wb-retry" class="btn btn-primary">Try Again</button>
            </div>

            <!-- Wheelbase listing-details -->
            <div id="wb-root">
              <listing-details
                id="wb-listing-details"
                dealer-id={DEALER_ID}
                rental-id={String(wbId)}
                locale="en-us"
                primary-color="#EA5E2D"
                secondary-color="#314B6E"
                text-color="#0D141C"
                text-secondary-color="#58585A"
                surface-color="#F4FBFE"
              ></listing-details>
            </div>
          </div>
        </section>

        <!-- Return navigation -->
        <section class="bg-surface border-t border-border section-sm">
          <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8 flex flex-wrap items-center justify-between gap-4">
            <a href={`/vehicles/${vehicle.slug}/`} class="inline-flex items-center gap-2 text-sm text-ink-secondary hover:text-brand transition-colors">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>
              Vehicle details
            </a>
            <a href="/vehicles/" class="inline-flex items-center gap-2 text-sm text-ink-secondary hover:text-brand transition-colors">
              Browse full fleet
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
            </a>
          </div>
        </section>
      </>
    )}
  </main>

  <Footer />
</BaseLayout>

<script>
  const WIDGET_SCRIPT_URL = "https://d2toxav8qvoos4.cloudfront.net/latest/wheelbase-widget.js";
  const LOAD_FLAG = "__305fleet_wheelbase_loaded";

  function showError() {
    document.getElementById("wb-loading")?.classList.add("hidden");
    document.getElementById("wb-error")?.classList.remove("hidden");
    document.getElementById("wb-root")?.classList.add("hidden");
  }

  function showListing() {
    document.getElementById("wb-loading")?.classList.add("hidden");
    document.getElementById("wb-error")?.classList.add("hidden");
    document.getElementById("wb-root")?.classList.remove("hidden");
  }

  async function loadWidget() {
    if (window[LOAD_FLAG]) return;
    window[LOAD_FLAG] = true;

    try {
      if (customElements.get("listing-details")) {
        showListing();
        return;
      }
      await import(WIDGET_SCRIPT_URL);
      await customElements.whenDefined("listing-details");
      showListing();
    } catch (err) {
      console.error("[305Fleet] Wheelbase listing-details failed to load:", err);
      showError();
    }
  }

  document.getElementById("wb-retry")?.addEventListener("click", () => {
    window[LOAD_FLAG] = false;
    document.getElementById("wb-error")?.classList.add("hidden");
    document.getElementById("wb-loading")?.classList.remove("hidden");
    loadWidget();
  });

  loadWidget();
</script>