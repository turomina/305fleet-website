---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/base/Header.astro";
import Footer from "../components/base/Footer.astro";
---

<BaseLayout
  title="How It Works"
  description="How direct vehicle rentals work with 305 Fleet — choose your vehicle, select dates and airport, complete your reservation, and pick up contactlessly at MIA, FLL, or PBI."
>
  <Header />

  <main id="main-content" class="flex-1">
    <!-- Hero -->
    <section class="section-sm gradient-dark text-white">
      <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
        <p class="text-accent font-semibold tracking-[0.12em] uppercase text-sm mb-4">How It Works</p>
        <h1 class="text-4xl sm:text-5xl font-bold tracking-tight">Simple, direct, contactless.</h1>
        <p class="mt-4 text-lg text-white/70 max-w-xl">
          Four steps from browsing to driving. No counter lines, no paperwork delays — just a clean vehicle ready when you arrive.
        </p>
      </div>
    </section>

    <!-- Steps -->
    <section class="section bg-surface">
      <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
        <div class="space-y-12">
          {[
            { num: "01", title: "Choose Your Vehicle", desc: "Browse our fleet of newer, well-maintained vehicles. Real photos, full specifications, no 'or similar' substitutions. Each listing shows passenger capacity, luggage space, and fuel type so you know exactly what you're getting.", icon: "car" },
            { num: "02", title: "Select Dates & Airport", desc: "Pick your rental dates and choose your airport — MIA, FLL, or PBI. We confirm availability for your selected vehicle. Airport parking charges are disclosed in reservation terms.", icon: "calendar" },
            { num: "03", title: "Complete Reservation", desc: "Provide the required information to confirm your direct rental. Your reservation is secured once the requirements are completed and confirmed.", icon: "shield" },
            { num: "04", title: "Receive Private Instructions", desc: "Before your pickup time, you'll receive your exact vehicle location privately — including garage, level, zone or row, and space number. No wandering through parking structures.", icon: "map" },
            { num: "05", title: "Contactless Pickup", desc: "Walk to your vehicle's exact location. Access it using the private instructions provided. No counter, no keys to collect — just get in and drive.", icon: "key" },
            { num: "06", title: "Contactless Return", desc: "Park in the instructed facility. Photograph the vehicle location. Confirm the garage, level, and space in writing. Secure the key and garage ticket per the private return procedure.", icon: "check" },
          ].map((step, i) => (
            <div class="flex flex-col sm:flex-row gap-6 sm:gap-10 items-start">
              <div class="flex-shrink-0 w-16 h-16 sm:w-20 sm:h-20 rounded-2xl bg-brand-50 flex items-center justify-center">
                <span class="text-2xl sm:text-3xl font-bold text-brand-200">{step.num}</span>
              </div>
              <div class="flex-1 pt-2">
                <h2 class="text-2xl font-bold text-ink mb-3">{step.title}</h2>
                <p class="text-ink-secondary leading-relaxed text-base">{step.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Airport Summary -->
    <section class="section bg-brand-50">
      <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
        <h2 class="text-3xl font-bold text-ink text-center mb-8">Airport Pickup Locations</h2>
        <div class="grid grid-cols-1 gap-6 sm:grid-cols-3">
          {[
            { code: "MIA", name: "Miami International", desc: "Dolphin, Flamingo & Ibis garages", href: "/locations/miami-international-airport/" },
            { code: "FLL", name: "Fort Lauderdale", desc: "Cypress Garage, Level 7, Zone 7NN", href: "/locations/fort-lauderdale-airport/" },
            { code: "PBI", name: "Palm Beach", desc: "Long-Term Garage 1 or 2", href: "/locations/palm-beach-airport/" },
          ].map(a => (
            <a href={a.href} class="bg-white rounded-2xl p-8 text-center border border-border hover:border-brand hover:shadow-lg transition-all group">
              <div class="text-4xl font-bold text-accent mb-3">{a.code}</div>
              <h3 class="font-semibold text-ink group-hover:text-brand transition-colors">{a.name}</h3>
              <p class="mt-1 text-sm text-ink-secondary">{a.desc}</p>
            </a>
          ))}
        </div>
        <p class="mt-6 text-sm text-ink-tertiary text-center">
          Airport parking charges associated with pickup and post-rental vehicle retrieval are the renter's responsibility — disclosed in reservation terms.
        </p>
      </div>
    </section>

    <!-- Final CTA -->
    <section class="section gradient-brand text-white text-center">
      <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
        <h2 class="text-4xl font-bold tracking-tight">Ready to get started?</h2>
        <p class="mt-4 text-lg text-white/70">Browse our fleet and find the right vehicle for your trip.</p>
        <div class="mt-6 flex flex-col sm:flex-row justify-center gap-4">
          <a href="/vehicles/" class="btn btn-light btn-primary-lg">Book Now</a>
          <a href="/contact/" class="btn px-6 py-4 text-base font-semibold text-white border-2 border-white/30 rounded-lg hover:bg-white/10 transition-all">Contact Us</a>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>