---
// Variant A — Streamlined Wheelbase Complete Store
// Route: /book-store-preview/ — preview only, not in production navigation

import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/base/Header.astro";
import Footer from "../components/base/Footer.astro";
import { DEALER_ID } from "../data/wheelbase-mapping";
---

<BaseLayout
  title="Book a Vehicle"
  description="Browse real-time availability and book directly with 305 Fleet."
  noindex={true}
>
  <Header />

  <main id="main-content" class="flex-1">
    <!-- Minimal page header — transactional, not a marketing hero -->
    <section class="bg-navy-900 text-white section-sm">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <h1 class="text-2xl sm:text-3xl font-bold tracking-tight">Book your rental</h1>
        <p class="mt-2 text-white/70 max-w-3xl text-sm sm:text-base">
          Select your dates to see available vehicles and real-time pricing.
        </p>
      </div>
    </section>

    <!-- Delivery options notice — compact and factual -->
    <section class="bg-brand-50 border-b border-brand-100">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-3">
        <div class="flex flex-wrap items-start gap-x-4 gap-y-1 text-xs sm:text-sm text-ink-secondary">
          <span class="inline-flex items-center gap-1">
            <svg class="w-3.5 h-3.5 text-green-600 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
            <span><strong class="text-ink">Free pickup:</strong> Pembroke Pines</span>
          </span>
          <span class="inline-flex items-center gap-1">
            <svg class="w-3.5 h-3.5 text-green-600 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
            <span><strong class="text-ink">Free delivery:</strong> MIA, FLL</span>
          </span>
          <span class="inline-flex items-center gap-1">
            <svg class="w-3.5 h-3.5 text-amber-600 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            <span><strong class="text-ink">Paid delivery:</strong> PBI &amp; service area</span>
          </span>
        </div>
        <p class="mt-1.5 text-xs text-ink-tertiary">
          Airport parking charges are the guest's responsibility. Special delivery is subject to confirmation and applicable fees.
        </p>
      </div>
    </section>

    <!-- Wheelbase Store — full-width transactional area -->
    <section class="bg-surface">
      <div class="mx-auto max-w-7xl px-0 sm:px-2 lg:px-4">

        <!-- Loading state -->
        <div id="wb-loading" class="py-16 text-center">
          <div class="inline-block w-8 h-8 border-3 border-brand-200 border-t-brand rounded-full animate-spin mb-4"></div>
          <p class="text-ink-secondary text-lg">Loading availability&hellip;</p>
        </div>

        <!-- Error state (hidden by default) -->
        <div id="wb-error" class="hidden py-16 text-center">
          <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-accent-50 mb-4">
            <svg class="w-8 h-8 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-ink mb-2">Booking system unavailable</h3>
          <p class="text-ink-secondary max-w-md mx-auto mb-6">
            We're having trouble loading our booking system. This is usually temporary — please try again.
          </p>
          <button type="button" id="wb-retry" class="btn btn-primary">Try Again</button>
          <p class="mt-4 text-sm text-ink-tertiary">
            If the problem persists, <a href="/contact/" class="text-brand underline hover:text-brand-400">contact us</a> for availability.
          </p>
        </div>

        <!-- Wheelbase widget container -->
        <div id="wb-root">
          <wheelbase-store
            id="wheelbase-store"
            dealer-id={DEALER_ID}
            store-type="auto"
            hide-hero="true"
            locale="en-us"
            primary-color="#EA5E2D"
            secondary-color="#314B6E"
            text-color="#0D141C"
            text-secondary-color="#58585A"
            surface-color="#F4FBFE"
          ></wheelbase-store>
        </div>

      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>

<script>
  const WIDGET_SCRIPT_URL = "https://d2toxav8qvoos4.cloudfront.net/latest/wheelbase-widget.js";
  const LOAD_FLAG = "__305fleet_wheelbase_loaded";

  function showError() {
    document.getElementById("wb-loading")?.classList.add("hidden");
    document.getElementById("wb-error")?.classList.remove("hidden");
    document.getElementById("wb-root")?.classList.add("hidden");
  }

  function showStore() {
    document.getElementById("wb-loading")?.classList.add("hidden");
    document.getElementById("wb-error")?.classList.add("hidden");
    document.getElementById("wb-root")?.classList.remove("hidden");
  }

  async function loadWidget() {
    if (window[LOAD_FLAG]) return;
    window[LOAD_FLAG] = true;

    try {
      if (customElements.get("wheelbase-store")) {
        showStore();
        return;
      }
      await import(WIDGET_SCRIPT_URL);
      await customElements.whenDefined("wheelbase-store");
      showStore();
    } catch (err) {
      console.error("[305Fleet] Wheelbase widget failed to load:", err);
      showError();
    }
  }

  document.getElementById("wb-retry")?.addEventListener("click", () => {
    window[LOAD_FLAG] = false;
    document.getElementById("wb-error")?.classList.add("hidden");
    document.getElementById("wb-loading")?.classList.remove("hidden");
    loadWidget();
  });

  loadWidget();
</script>