---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/base/Header.astro";
import Footer from "../components/base/Footer.astro";
---

<BaseLayout
  title="Reviews"
  description="Customer reviews for 305 Fleet — South Florida vehicle rentals."
>
  <Header />

  <main id="main-content" class="flex-1 bg-gray-50">
    <div class="mx-auto max-w-5xl px-4 py-12 sm:px-6 lg:px-8 lg:py-16">
      <h1 class="text-3xl font-bold text-gray-900">Customer Reviews</h1>
      <p class="mt-3 text-lg text-gray-500">
        What our customers say about renting with 305 Fleet.
      </p>

      <!-- Rating summary -->
      <div class="mt-8 flex items-center gap-6 rounded-xl bg-white border border-gray-200 p-6">
        <div class="text-center">
          <div class="text-4xl font-bold text-gray-900">5.0</div>
          <div class="mt-1 flex">
            {[1,2,3,4,5].map(() => (
              <svg class="h-5 w-5 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.799-2.034a1 1 0 00-1.176 0l-2.799 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
              </svg>
            ))}
          </div>
          <p class="mt-1 text-sm text-gray-500">Customer rating</p>
        </div>
        <div class="h-12 w-px bg-gray-200"></div>
        <p class="text-sm text-gray-600">
          We're building our direct review system. In the meantime, check back soon for customer reviews.
        </p>
      </div>

      <!-- Review placeholders -->
      <div class="mt-8 space-y-4">
        {[1, 2, 3].map(() => (
          <div class="rounded-xl bg-white border border-gray-200 p-6">
            <div class="flex items-center justify-between">
              <div class="flex items-center gap-3">
                <div class="h-10 w-10 rounded-full bg-gray-200 flex items-center justify-center text-gray-500 font-medium">
                  ★
                </div>
                <div>
                  <p class="font-medium text-gray-900">Customer name</p>
                  <p class="text-sm text-gray-500">Verified customer</p>
                </div>
              </div>
              <div class="flex">
                {[1,2,3,4,5].map(() => (
                  <svg class="h-4 w-4 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
                    <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.799-2.034a1 1 0 00-1.176 0l-2.799 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                  </svg>
                ))}
              </div>
            </div>
            <p class="mt-3 text-sm text-gray-600">
              Review content will be displayed here. We're building our direct review system.
            </p>
          </div>
        ))}
      </div>

      <div class="mt-8 text-center">
        <a href="/contact/" class="inline-flex items-center rounded-lg bg-brand px-6 py-3 text-sm font-semibold text-white hover:bg-brand-light">
          Become a Customer
        </a>
      </div>
    </div>
  </main>

  <Footer />
</BaseLayout>