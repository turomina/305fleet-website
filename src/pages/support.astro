---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/base/Header.astro";
import Footer from "../components/base/Footer.astro";
---

<BaseLayout
  title="Support"
  description="305 Fleet customer support — get help during your rental, request extensions, or report an issue."
>
  <Header />

  <main id="main-content" class="flex-1 bg-white">
    <div class="mx-auto max-w-4xl px-4 py-12 sm:px-6 lg:px-8 lg:py-16">
      <h1 class="text-3xl font-bold text-gray-900">Support</h1>
      <p class="mt-3 text-lg text-gray-500">
        Need help? We're here for you — before, during, and after your rental.
      </p>

      <div class="mt-8 grid grid-cols-1 gap-6 sm:grid-cols-2">
        <div class="rounded-xl border border-gray-200 p-6">
          <h2 class="text-lg font-semibold text-gray-900">During Your Rental</h2>
          <p class="mt-2 text-sm text-gray-600">
            Vehicle issues, roadside assistance, questions about your vehicle, or need an extension?
            Contact us immediately.
          </p>
          <div class="mt-4 space-y-2">
            <a href="tel:" class="flex items-center gap-2 text-sm font-medium text-brand hover:underline">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
              Call us (number coming soon)
            </a>
            <a href="#" class="flex items-center gap-2 text-sm font-medium text-brand hover:underline">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.148-.669-1.611-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347" /></svg>
              WhatsApp (coming soon)
            </a>
          </div>
        </div>

        <div class="rounded-xl border border-gray-200 p-6">
          <h2 class="text-lg font-semibold text-gray-900">Before You Book</h2>
          <p class="mt-2 text-sm text-gray-600">
            Questions about vehicle availability, pricing, requirements, or policies?
            Check our FAQ or contact us.
          </p>
          <div class="mt-4">
            <a href="/faq/" class="inline-flex items-center text-sm font-medium text-brand hover:underline">
              View FAQ →
            </a>
          </div>
        </div>

        <div class="rounded-xl border border-gray-200 p-6">
          <h2 class="text-lg font-semibold text-gray-900">Roadside Assistance</h2>
          <p class="mt-2 text-sm text-gray-600">
            If you experience a vehicle issue during your rental, contact us immediately.
            Roadside assistance details are provided in your rental agreement.
          </p>
        </div>

        <div class="rounded-xl border border-gray-200 p-6">
          <h2 class="text-lg font-semibold text-gray-900">Extensions & Returns</h2>
          <p class="mt-2 text-sm text-gray-600">
            Need to extend your rental or adjust your return time? Contact us as soon as possible.
            Extensions are subject to availability and additional charges.
          </p>
          <a href="/rental-policies/" class="mt-3 inline-flex items-center text-sm font-medium text-brand hover:underline">
            View Policies →
          </a>
        </div>
      </div>

      <div class="mt-8 rounded-lg bg-yellow-50 border border-yellow-300 p-4">
        <p class="text-sm text-yellow-900">
          ⚠️ For emergencies, dial 911 first. For vehicle-related issues, contact us after ensuring
          your safety.
        </p>
      </div>
    </div>
  </main>

  <Footer />
</BaseLayout>