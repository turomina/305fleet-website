---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/base/Header.astro";
import Footer from "../../components/base/Footer.astro";
---

<BaseLayout
  title="Miami International Airport (MIA)"
  description="305 Fleet airport delivery at Miami International Airport (MIA). Vehicle pickup and return at MIA."
>
  <Header />

  <main id="main-content" class="flex-1 bg-white">
    <div class="mx-auto max-w-4xl px-4 py-12 sm:px-6 lg:px-8 lg:py-16">
      <div class="flex items-center gap-3">
        <span class="text-4xl">✈️</span>
        <div>
          <h1 class="text-3xl font-bold text-gray-900">Miami International Airport</h1>
          <p class="text-lg text-gray-500">MIA — Miami, Florida</p>
        </div>
      </div>

      <div class="mt-8 prose prose-lg prose-gray max-w-none">
        <p>
          We deliver vehicles directly to Miami International Airport (MIA) for your convenience.
          No shuttle buses, no counter lines — we meet you with your vehicle ready to go.
        </p>
      </div>

      <div class="mt-8 rounded-xl border border-gray-200 p-6">
        <h2 class="text-xl font-semibold text-gray-900">How MIA Pickup Works</h2>
        <ol class="mt-4 space-y-3">
          <li class="flex gap-3"><span class="font-bold text-brand">1.</span> <span>Book your vehicle with MIA as your pickup location.</span></li>
          <li class="flex gap-3"><span class="font-bold text-brand">2.</span> <span>Provide your flight number — we track your arrival in real time.</span></li>
          <li class="flex gap-3"><span class="font-bold text-brand">3.</span> <span>Upon arrival, follow our pickup instructions (specific meeting point provided at booking confirmation).</span></li>
          <li class="flex gap-3"><span class="font-bold text-brand">4.</span> <span>We do a walk-around inspection together and hand over the keys.</span></li>
          <li class="flex gap-3"><span class="font-bold text-brand">5.</span> <span>You're on your way.</span></li>
        </ol>
      </div>

      <div class="mt-6 rounded-xl border border-gray-200 p-6">
        <h2 class="text-xl font-semibold text-gray-900">Return</h2>
        <p class="mt-3 text-gray-600">
          Return your vehicle at the agreed time. We'll meet you at the designated location,
          conduct a final inspection together, and you're free to head to your terminal.
        </p>
      </div>

      <div class="mt-6 grid grid-cols-1 gap-4 sm:grid-cols-3">
        <div class="rounded-lg bg-brand-pale p-4 text-center">
          <p class="text-2xl font-bold text-brand">MIA</p>
          <p class="text-sm text-gray-600">Airport Code</p>
        </div>
        <div class="rounded-lg bg-brand-pale p-4 text-center">
          <p class="text-2xl font-bold text-brand">Miami</p>
          <p class="text-sm text-gray-600">City</p>
        </div>
        <div class="rounded-lg bg-brand-pale p-4 text-center">
          <p class="text-2xl font-bold text-brand">2100 NW 42nd Ave</p>
          <p class="text-sm text-gray-600">Miami, FL 33142</p>
        </div>
      </div>

      <div class="mt-8 flex flex-col sm:flex-row gap-3">
        <a href="/vehicles/" class="inline-flex items-center justify-center rounded-lg bg-brand px-6 py-3 text-sm font-semibold text-white hover:bg-brand-light">
          View Available Vehicles
        </a>
        <a href="/contact/" class="inline-flex items-center justify-center rounded-lg border border-gray-300 px-6 py-3 text-sm font-semibold text-gray-700 hover:border-brand hover:text-brand">
          Contact Us
        </a>
      </div>
    </div>
  </main>

  <Footer />
</BaseLayout>