---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/base/Header.astro";
import Footer from "../components/base/Footer.astro";

const faqs = [
  { q: "How does airport pickup work?", a: "After your reservation is confirmed, you'll receive the exact garage, level, and parking space location privately before your pickup time. Access the vehicle using the private instructions provided. It's contactless — no counter visit needed." },
  { q: "Which airports do you serve?", a: "Miami International (MIA), Fort Lauderdale-Hollywood International (FLL), and Palm Beach International (PBI). Contactless pickup and return are available at all three." },
  { q: "Who pays for airport parking?", a: "You're responsible for the parking charge to exit the garage at pickup, as well as the parking charge associated with post-rental vehicle retrieval. These are disclosed in the reservation terms and are separate from the vehicle rental." },
  { q: "Can I choose a specific garage at MIA?", a: "We select the garage operationally for each trip — either Dolphin, Flamingo, or Ibis Garage. You'll receive the exact garage and location privately before your reservation begins." },
  { q: "Is Premium Parking available at PBI?", a: "Yes, Premium Parking may be available by request and operational approval. It's not the default option. When requested, any parking cost differences will be disclosed." },
  { q: "What's the return process?", a: "Park in the instructed facility. Photograph the vehicle and its location. Confirm the garage, level, zone or row, and space number in writing. Secure the key and new garage-entry ticket per the private return procedure." },
  { q: "Is the vehicle I see in the listing the one I get?", a: "Yes. Every vehicle in our fleet is individually photographed and listed. No 'or similar' substitutions — what you see is what you drive." },
  { q: "Do you offer long-term rentals?", a: "Yes. We offer daily, weekly, and monthly options. Business and corporate rentals are also available." },
  { q: "How do I contact 305 Fleet?", a: "You can reach us through the contact channels listed on our contact page. We're a local South Florida team — not a remote call center." },
  { q: "Is there a security deposit?", a: "Reservation requirements will be confirmed during the booking process. Final terms are governed by the 305Fleet rental agreement." },
];
---

<BaseLayout
  title="FAQ"
  description="Frequently asked questions about 305 Fleet direct vehicle rentals — airport pickup, parking charges, vehicle selection, and more."
>
  <Header />

  <main id="main-content" class="flex-1">
    <section class="section-sm gradient-dark text-white">
      <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
        <p class="text-accent font-semibold tracking-[0.12em] uppercase text-sm mb-4">FAQ</p>
        <h1 class="text-4xl sm:text-5xl font-bold tracking-tight">Common questions.</h1>
        <p class="mt-4 text-lg text-white/70">Everything you need to know about renting with 305 Fleet.</p>
      </div>
    </section>

    <section class="section bg-surface">
      <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
        <div class="space-y-4">
          {faqs.map((faq, i) => (
            <details class="group rounded-2xl border border-border bg-white p-6 transition-all duration-300 hover:border-brand-200" open={i === 0}>
              <summary class="flex items-center justify-between cursor-pointer list-none">
                <h2 class="text-lg font-semibold text-ink pr-4">{faq.q}</h2>
                <svg class="w-5 h-5 text-ink-tertiary shrink-0 transition-transform duration-300 group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
              </summary>
              <p class="mt-4 text-ink-secondary leading-relaxed">{faq.a}</p>
            </details>
          ))}
        </div>

        <div class="mt-10 text-center">
          <p class="text-ink-secondary mb-4">Still have questions?</p>
          <a href="/contact/" class="btn btn-primary">Contact Us</a>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>