---
// /book/ — Wheelbase embedded store (W1 Proof of Concept)
// Route: English-only, preview deployment only, not in production navigation

import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/base/Header.astro";
import Footer from "../components/base/Footer.astro";

const dealerId = "5011907";
---

<BaseLayout
  title="Book a Vehicle"
  description="Browse available vehicles, select dates, and book directly with 305 Fleet. Contactless airport pickup at MIA, FLL, and PBI."
>
  <Header />

  <main id="main-content" class="flex-1">
    <!-- 305Fleet Branded Hero -->
    <section class="section-sm gradient-dark text-white">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <p class="text-accent font-semibold tracking-[0.12em] uppercase text-sm mb-4">Direct Booking</p>
        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold tracking-tight">Book your rental.</h1>
        <p class="mt-4 text-lg text-white/70 max-w-2xl">
          Browse real-time availability, select your dates, and complete your reservation.
          Contactless pickup from designated airport parking at MIA, FLL, and PBI.
        </p>
        <!-- Trust bar -->
        <div class="mt-6 flex flex-wrap gap-4 text-sm text-white/60">
          <span class="inline-flex items-center gap-1.5">
            <svg class="w-4 h-4 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
            Real-time availability
          </span>
          <span class="inline-flex items-center gap-1.5">
            <svg class="w-4 h-4 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
            Instant pricing
          </span>
          <span class="inline-flex items-center gap-1.5">
            <svg class="w-4 h-4 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
            Contactless pickup
          </span>
        </div>
      </div>
    </section>

    <!-- Wheelbase Store Container -->
    <section class="section bg-surface">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">

        <!-- Loading state -->
        <div id="wb-loading" class="py-16 text-center">
          <div class="inline-block w-8 h-8 border-3 border-brand-200 border-t-brand rounded-full animate-spin mb-4"></div>
          <p class="text-ink-secondary text-lg">Loading availability&hellip;</p>
          <p class="text-ink-tertiary text-sm mt-1">This may take a moment.</p>
        </div>

        <!-- Error state (hidden by default) -->
        <div id="wb-error" class="hidden py-16 text-center">
          <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-accent-50 mb-4">
            <svg class="w-8 h-8 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-ink mb-2">Booking system unavailable</h3>
          <p class="text-ink-secondary max-w-md mx-auto mb-6">
            We're having trouble loading our booking system. This is usually temporary — please try again in a few minutes.
          </p>
          <button
            type="button"
            id="wb-retry"
            class="btn btn-primary"
          >
            Try Again
          </button>
          <p class="mt-4 text-sm text-ink-tertiary">
            If the problem persists, <a href="/contact/" class="text-brand underline hover:text-brand-400">contact us</a> for availability.
          </p>
        </div>

        <!-- Wheelbase widget container -->
        <div id="wb-root">
          <wheelbase-store
            id="wheelbase-store"
            dealer-id={dealerId}
            store-type="auto"
            hide-hero="true"
            locale="en-us"
            primary-color="#EA5E2D"
            secondary-color="#314B6E"
            text-color="#0D141C"
            text-secondary-color="#58585A"
            surface-color="#F4FBFE"
          ></wheelbase-store>
        </div>

      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>

<script>
  // Single-instance guard: prevent duplicate script loading or custom-element registration
  const WIDGET_SCRIPT_URL = "https://d2toxav8qvoos4.cloudfront.net/latest/wheelbase-widget.js";
  const LOAD_FLAG = "__305fleet_wheelbase_loaded";

  function showError() {
    document.getElementById("wb-loading")?.classList.add("hidden");
    document.getElementById("wb-error")?.classList.remove("hidden");
    document.getElementById("wb-root")?.classList.add("hidden");
  }

  function showStore() {
    document.getElementById("wb-loading")?.classList.add("hidden");
    document.getElementById("wb-error")?.classList.add("hidden");
    document.getElementById("wb-root")?.classList.remove("hidden");
  }

  async function loadWidget() {
    // Guard against double-load
    if (window[LOAD_FLAG]) return;
    window[LOAD_FLAG] = true;

    try {
      // Check if the custom element is already registered (from a prior navigation or HMR)
      if (customElements.get("wheelbase-store")) {
        showStore();
        return;
      }

      await import(WIDGET_SCRIPT_URL);

      // Wait briefly for the custom element to upgrade
      await customElements.whenDefined("wheelbase-store");
      showStore();
    } catch (err) {
      console.error("[305Fleet] Wheelbase widget failed to load:", err);
      showError();
    }
  }

  // Retry button
  document.getElementById("wb-retry")?.addEventListener("click", () => {
    window[LOAD_FLAG] = false;
    document.getElementById("wb-error")?.classList.add("hidden");
    document.getElementById("wb-loading")?.classList.remove("hidden");
    loadWidget();
  });

  // Start loading
  loadWidget();
</script>