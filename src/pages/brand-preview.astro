---
import BaseLayout from "../layouts/BaseLayout.astro";
import LogoA from "../components/brand/LogoA.astro";
import LogoB from "../components/brand/LogoB.astro";
import LogoC from "../components/brand/LogoC.astro";
import Button from "../components/ui/Button.astro";
import SectionHeading from "../components/ui/SectionHeading.astro";
import FeatureCard from "../components/ui/FeatureCard.astro";
import TrustBadge from "../components/ui/TrustBadge.astro";
import AirportChip from "../components/ui/AirportChip.astro";
import InfoBanner from "../components/ui/InfoBanner.astro";
import VehicleCard from "../components/ui/VehicleCard.astro";
import CtaBand from "../components/ui/CtaBand.astro";
import vehicles from "../data/vehicles.json";

const sampleVehicle = vehicles[0];
const noindex = true; // Keep noindex on this page
---

<BaseLayout title="Brand Preview" noindex={noindex} description="Internal brand preview — not for public access.">
  <style>
    /* Page-specific styles only — no global overrides */
    .preview-section {
      padding: 3rem 0;
      border-bottom: 1px solid var(--color-border);
    }
    .swatch {
      width: 100%;
      aspect-ratio: 1;
      border-radius: 8px;
      border: 1px solid var(--color-border);
    }
    .logo-frame {
      background: var(--color-surface);
      border: 1px solid var(--color-border);
      border-radius: 12px;
      padding: 2rem;
      text-align: center;
    }
    .logo-frame.dark {
      background: var(--color-navy-900);
      border-color: var(--color-navy-700);
    }
    .type-sample {
      margin-bottom: 1rem;
    }
  </style>

  <main id="main-content" class="flex-1 bg-surface">
    <!-- Header note -->
    <div class="bg-navy-900 text-white py-8">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="flex items-center gap-3 mb-2">
          <span class="rounded-full bg-coral-500 px-3 py-1 text-xs font-bold uppercase tracking-wide">Internal</span>
          <span class="text-sm text-navy-100">Brand Preview · Not linked in navigation</span>
        </div>
        <h1 class="text-3xl font-bold tracking-tight">305Fleet Design System Preview</h1>
        <p class="mt-2 text-base text-navy-100 max-w-2xl">
          This page shows the proposed visual identity: three logo directions, color palette,
          typography, component library, and the How It Works prototype.
          Ian reviews this page before selecting a direction.
        </p>
      </div>
    </div>

    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">

      <!-- ════════ LOGO DIRECTIONS ════════ -->
      <section class="preview-section">
        <SectionHeading
          title="Logo Directions"
          subtitle="Three flat vector concepts. Each shown on light and dark backgrounds, plus compact and favicon previews. No final selection yet — Ian picks one."
          level="h2"
        />

        <div class="mt-10 grid grid-cols-1 gap-8 lg:grid-cols-3">
          <!-- Direction A -->
          <div>
            <h3 class="text-lg font-semibold text-navy-900 mb-4">Direction A — "Route 305"</h3>
            <p class="text-sm text-ink-secondary mb-6">
              A route-shield badge with "305" and a coral directional arrow. "FLEET" sits
              alongside in a strong weight. Clean, official, road-sign inspired.
            </p>

            <!-- Light background -->
            <div class="logo-frame mb-4">
              <p class="text-xs text-ink-tertiary mb-2 text-left font-medium">Light background</p>
              <div class="flex justify-center py-4">
                <LogoA />
              </div>
            </div>

            <!-- Dark background -->
            <div class="logo-frame dark mb-4">
              <p class="text-xs text-navy-200 mb-2 text-left font-medium">Dark background</p>
              <div class="flex justify-center py-4">
                <svg viewBox="0 0 280 64" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="305 Fleet logo A, dark variant">
                  <svg x="0" y="4" width="56" height="56" viewBox="0 0 56 56">
                    <path d="M28 4 L48 12 L48 30 C48 42 38 50 28 54 C18 50 8 42 8 30 L8 12 Z" fill="#FFFFFF" stroke="none"/>
                    <path d="M28 8 L44 14 L44 30 C44 40 36 46 28 50 C20 46 12 40 12 30 L12 14 Z" fill="none" stroke="#1769D2" stroke-width="1.5" opacity="0.4"/>
                    <text x="28" y="36" text-anchor="middle" font-family="Manrope, system-ui, sans-serif" font-size="18" font-weight="800" fill="#0B1F33" letter-spacing="-1">305</text>
                    <path d="M28 42 L33 47 L28 52 L23 47 Z" fill="#F25C3D"/>
                  </svg>
                  <text x="68" y="42" font-family="Manrope, system-ui, sans-serif" font-size="26" font-weight="700" fill="#FFFFFF" letter-spacing="-0.5">FLEET</text>
                </svg>
              </div>
            </div>

            <!-- Compact mark -->
            <div class="flex gap-4 items-end">
              <div class="logo-frame" style="padding: 1rem;">
                <p class="text-xs text-ink-tertiary mb-2 text-left font-medium">Compact 305 mark</p>
                <svg width="48" height="48" viewBox="0 0 56 56" xmlns="http://www.w3.org/2000/svg">
                  <path d="M28 4 L48 12 L48 30 C48 42 38 50 28 54 C18 50 8 42 8 30 L8 12 Z" fill="#0B1F33"/>
                  <text x="28" y="36" text-anchor="middle" font-family="Manrope, sans-serif" font-size="18" font-weight="800" fill="#FFFFFF">305</text>
                  <path d="M28 42 L33 47 L28 52 L23 47 Z" fill="#F25C3D"/>
                </svg>
              </div>
              <div class="logo-frame" style="padding: 1rem;">
                <p class="text-xs text-ink-tertiary mb-2 text-left font-medium">Favicon (32px)</p>
                <svg width="32" height="32" viewBox="0 0 56 56" xmlns="http://www.w3.org/2000/svg">
                  <path d="M28 4 L48 12 L48 30 C48 42 38 50 28 54 C18 50 8 42 8 30 L8 12 Z" fill="#0B1F33"/>
                  <text x="28" y="38" text-anchor="middle" font-family="Manrope, sans-serif" font-size="22" font-weight="800" fill="#FFFFFF">3</text>
                  <path d="M28 44 L33 49 L28 54 L23 49 Z" fill="#F25C3D"/>
                </svg>
              </div>
            </div>
          </div>

          <!-- Direction B -->
          <div>
            <h3 class="text-lg font-semibold text-navy-900 mb-4">Direction B — "Highway 305"</h3>
            <p class="text-sm text-ink-secondary mb-6">
              "305" in heavy bold with dashed highway lines running through the numbers.
              "FLEET" in a lighter companion weight. Modern, fast, automotive without clichés.
            </p>

            <!-- Light background -->
            <div class="logo-frame mb-4">
              <p class="text-xs text-ink-tertiary mb-2 text-left font-medium">Light background</p>
              <div class="flex justify-center py-4">
                <LogoB />
              </div>
            </div>

            <!-- Dark background -->
            <div class="logo-frame dark mb-4">
              <p class="text-xs text-navy-200 mb-2 text-left font-medium">Dark background</p>
              <div class="flex justify-center py-4">
                <svg viewBox="0 0 280 64" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="305 Fleet logo B, dark variant">
                  <text x="0" y="44" font-family="Manrope, system-ui, sans-serif" font-size="40" font-weight="800" fill="#FFFFFF" letter-spacing="-2">305</text>
                  <line x1="2" y1="34" x2="18" y2="34" stroke="#1769D2" stroke-width="2" stroke-dasharray="4 3"/>
                  <line x1="22" y1="34" x2="38" y2="34" stroke="#1769D2" stroke-width="2" stroke-dasharray="4 3"/>
                  <line x1="42" y1="34" x2="58" y2="34" stroke="#1769D2" stroke-width="2" stroke-dasharray="4 3"/>
                  <text x="74" y="42" font-family="Manrope, sans-serif" font-size="22" font-weight="600" fill="#FFFFFF" letter-spacing="1">FLEET</text>
                  <circle cx="74" cy="46" r="2.5" fill="#F25C3D"/>
                </svg>
              </div>
            </div>

            <!-- Compact mark -->
            <div class="flex gap-4 items-end">
              <div class="logo-frame" style="padding: 1rem;">
                <p class="text-xs text-ink-tertiary mb-2 text-left font-medium">Compact 305 mark</p>
                <svg width="48" height="48" viewBox="0 0 60 60" xmlns="http://www.w3.org/2000/svg">
                  <text x="30" y="40" text-anchor="middle" font-family="Manrope, sans-serif" font-size="36" font-weight="800" fill="#0B1F33" letter-spacing="-2">305</text>
                  <line x1="6" y1="32" x2="22" y2="32" stroke="#1769D2" stroke-width="2" stroke-dasharray="4 3"/>
                  <line x1="26" y1="32" x2="42" y2="32" stroke="#1769D2" stroke-width="2" stroke-dasharray="4 3"/>
                  <circle cx="50" cy="32" r="2" fill="#F25C3D"/>
                </svg>
              </div>
              <div class="logo-frame" style="padding: 1rem;">
                <p class="text-xs text-ink-tertiary mb-2 text-left font-medium">Favicon (32px)</p>
                <svg width="32" height="32" viewBox="0 0 60 60" xmlns="http://www.w3.org/2000/svg">
                  <text x="30" y="42" text-anchor="middle" font-family="Manrope, sans-serif" font-size="36" font-weight="800" fill="#FFFFFF">3</text>
                  <line x1="6" y1="34" x2="24" y2="34" stroke="#1769D2" stroke-width="2.5" stroke-dasharray="4 3"/>
                  <circle cx="50" cy="34" r="2.5" fill="#F25C3D"/>
                </svg>
              </div>
            </div>
          </div>

          <!-- Direction C -->
          <div>
            <h3 class="text-lg font-semibold text-navy-900 mb-4">Direction C — "305 Mark"</h3>
            <p class="text-sm text-ink-secondary mb-6">
              A circular "305" badge with a subtle directional notch. The wordmark
              reads as one unit: bold "305" + lighter "Fleet". Compact, versatile, brandable.
            </p>

            <!-- Light background -->
            <div class="logo-frame mb-4">
              <p class="text-xs text-ink-tertiary mb-2 text-left font-medium">Light background</p>
              <div class="flex justify-center py-4">
                <LogoC />
              </div>
            </div>

            <!-- Dark background -->
            <div class="logo-frame dark mb-4">
              <p class="text-xs text-navy-200 mb-2 text-left font-medium">Dark background</p>
              <div class="flex justify-center py-4">
                <svg viewBox="0 0 280 64" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="305 Fleet logo C, dark variant">
                  <svg x="2" y="6" width="52" height="52" viewBox="0 0 52 52">
                    <circle cx="26" cy="26" r="24" fill="#FFFFFF"/>
                    <path d="M40 12 L46 6 L44 18 Z" fill="#FFFFFF"/>
                    <circle cx="26" cy="26" r="20" fill="none" stroke="#1769D2" stroke-width="1" opacity="0.3"/>
                    <text x="26" y="33" text-anchor="middle" font-family="Manrope, sans-serif" font-size="17" font-weight="800" fill="#0B1F33" letter-spacing="-0.5">305</text>
                  </svg>
                  <text x="64" y="42" font-family="Manrope, sans-serif" font-size="24" font-weight="700" fill="#FFFFFF" letter-spacing="-0.5">
                    <tspan font-weight="800">305</tspan><tspan font-weight="500">Fleet</tspan>
                  </text>
                  <rect x="64" y="46" width="48" height="2" fill="#F25C3D" rx="1"/>
                </svg>
              </div>
            </div>

            <!-- Compact mark -->
            <div class="flex gap-4 items-end">
              <div class="logo-frame" style="padding: 1rem;">
                <p class="text-xs text-ink-tertiary mb-2 text-left font-medium">Compact 305 mark</p>
                <svg width="48" height="48" viewBox="0 0 52 52" xmlns="http://www.w3.org/2000/svg">
                  <circle cx="26" cy="26" r="24" fill="#0B1F33"/>
                  <path d="M40 12 L46 6 L44 18 Z" fill="#0B1F33"/>
                  <text x="26" y="33" text-anchor="middle" font-family="Manrope, sans-serif" font-size="17" font-weight="800" fill="#FFFFFF">305</text>
                </svg>
              </div>
              <div class="logo-frame" style="padding: 1rem;">
                <p class="text-xs text-ink-tertiary mb-2 text-left font-medium">Favicon (32px)</p>
                <svg width="32" height="32" viewBox="0 0 52 52" xmlns="http://www.w3.org/2000/svg">
                  <circle cx="26" cy="26" r="24" fill="#0B1F33"/>
                  <text x="26" y="34" text-anchor="middle" font-family="Manrope, sans-serif" font-size="22" font-weight="800" fill="#FFFFFF">3</text>
                </svg>
              </div>
            </div>
          </div>
        </div>

        <!-- Header/mobile preview context -->
        <div class="mt-10 p-6 rounded-xl border border-border bg-surface-light">
          <h4 class="text-sm font-semibold text-navy-900 mb-3">Desktop header preview (Direction A at 40px height)</h4>
          <div class="flex items-center justify-between p-4 bg-surface rounded-lg border border-border">
            <div class="flex items-center gap-3">
              <LogoA />
              <span class="hidden lg:inline-flex items-center gap-6 ml-8 text-sm font-medium text-ink-secondary">
                <a href="#" class="hover:text-blue-500">Vehicles</a>
                <a href="#" class="hover:text-blue-500">Locations</a>
                <a href="#" class="hover:text-blue-500">How It Works</a>
                <a href="#" class="hover:text-blue-500">About</a>
                <a href="#" class="hover:text-blue-500">Contact</a>
              </span>
            </div>
            <div class="flex items-center gap-3">
              <span class="text-sm font-medium text-ink-secondary">EN / ES</span>
              <Button variant="secondary" size="sm">Browse Vehicles</Button>
            </div>
          </div>
        </div>

        <!-- Footer preview -->
        <div class="mt-4 p-6 rounded-xl border border-border bg-navy-900">
          <h4 class="text-sm font-semibold text-white mb-3">Footer preview (Direction A on dark)</h4>
          <div class="flex items-center gap-8">
            <svg viewBox="0 0 280 64" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="305 Fleet footer logo">
              <svg x="0" y="4" width="56" height="56" viewBox="0 0 56 56">
                <path d="M28 4 L48 12 L48 30 C48 42 38 50 28 54 C18 50 8 42 8 30 L8 12 Z" fill="#FFFFFF"/>
                <text x="28" y="36" text-anchor="middle" font-family="Manrope, sans-serif" font-size="18" font-weight="800" fill="#0B1F33">305</text>
                <path d="M28 42 L33 47 L28 52 L23 47 Z" fill="#F25C3D"/>
              </svg>
              <text x="68" y="42" font-family="Manrope, sans-serif" font-size="26" font-weight="700" fill="#FFFFFF">FLEET</text>
            </svg>
            <div class="text-sm text-navy-200">
              <p>© 2026 Turomina LLC dba 305Fleet</p>
              <p>South Florida Vehicle Rentals · MIA · FLL · PBI</p>
            </div>
          </div>
        </div>
      </section>

      <!-- ════════ COLOR PALETTE ════════ -->
      <section class="preview-section">
        <SectionHeading
          title="Color Palette"
          subtitle="Navy and blue are primary. Coral is a sparing accent for highlights, not for main CTAs."
          level="h2"
        />

        <div class="mt-8 grid grid-cols-2 gap-4 sm:grid-cols-3 lg:grid-cols-4">
          <div>
            <div class="swatch" style="background: #0B1F33;"></div>
            <p class="mt-2 text-sm font-medium">Primary Navy</p>
            <p class="text-xs text-ink-tertiary">#0B1F33</p>
          </div>
          <div>
            <div class="swatch" style="background: #1769D2;"></div>
            <p class="mt-2 text-sm font-medium">Action Blue</p>
            <p class="text-xs text-ink-tertiary">#1769D2</p>
          </div>
          <div>
            <div class="swatch" style="background: #F25C3D;"></div>
            <p class="mt-2 text-sm font-medium">Accent Coral</p>
            <p class="text-xs text-ink-tertiary">#F25C3D · Use sparingly</p>
          </div>
          <div>
            <div class="swatch" style="background: #172033;"></div>
            <p class="mt-2 text-sm font-medium">Main Text</p>
            <p class="text-xs text-ink-tertiary">#172033</p>
          </div>
          <div>
            <div class="swatch" style="background: #647184;"></div>
            <p class="mt-2 text-sm font-medium">Secondary Text</p>
            <p class="text-xs text-ink-tertiary">#647184</p>
          </div>
          <div>
            <div class="swatch" style="background: #F5F7FA;"></div>
            <p class="mt-2 text-sm font-medium">Light Background</p>
            <p class="text-xs text-ink-tertiary">#F5F7FA</p>
          </div>
          <div>
            <div class="swatch" style="background: #DCE2EA;"></div>
            <p class="mt-2 text-sm font-medium">Border</p>
            <p class="text-xs text-ink-tertiary">#DCE2EA</p>
          </div>
          <div>
            <div class="swatch" style="background: #FFFFFF; border: 1px solid #DCE2EA;"></div>
            <p class="mt-2 text-sm font-medium">White</p>
            <p class="text-xs text-ink-tertiary">#FFFFFF</p>
          </div>
        </div>

        <!-- Navy scale -->
        <div class="mt-6">
          <p class="text-sm font-medium mb-2">Navy scale</p>
          <div class="flex gap-1">
            <div class="h-12 flex-1 rounded" style="background: #F0F3F7;"></div>
            <div class="h-12 flex-1 rounded" style="background: #D9E0EB;"></div>
            <div class="h-12 flex-1 rounded" style="background: #B3C2D7;"></div>
            <div class="h-12 flex-1 rounded" style="background: #7D95B4;"></div>
            <div class="h-12 flex-1 rounded" style="background: #4A6B91;"></div>
            <div class="h-12 flex-1 rounded" style="background: #2A4D72;"></div>
            <div class="h-12 flex-1 rounded" style="background: #1B3A5C;"></div>
            <div class="h-12 flex-1 rounded" style="background: #142E47;"></div>
            <div class="h-12 flex-1 rounded" style="background: #0E2235;"></div>
            <div class="h-12 flex-1 rounded" style="background: #0B1F33;"></div>
          </div>
          <div class="flex gap-1 mt-1">
            {["50","","","","","","","","","900"].map((l) => <div class="flex-1 text-center text-xs text-ink-tertiary">{l}</div>)}
          </div>
        </div>
      </section>

      <!-- ════════ TYPOGRAPHY ════════ -->
      <section class="preview-section">
        <SectionHeading
          title="Typography"
          subtitle="Manrope — a strong variable sans-serif. Loaded from Google Fonts with system-ui fallback."
          level="h2"
        />

        <!-- Font loading note -->
        <div class="mt-6 p-4 rounded-lg bg-surface-light border border-border">
          <p class="text-sm text-ink-secondary">
            <span class="font-semibold">Selected:</span> Manrope (variable, 200–800 weight) |
            <span class="font-semibold">Fallback:</span> system-ui, -apple-system, "Segoe UI", Roboto, sans-serif |
            <span class="font-semibold">Latin coverage:</span> Full (EN + ES)
          </p>
        </div>

        <!-- Type scale -->
        <div class="mt-8 space-y-4">
          <div class="type-sample">
            <span class="text-xs font-medium text-ink-tertiary">H1 / 48px / 800</span>
            <h1 class="text-5xl font-extrabold tracking-tight text-navy-900">South Florida's Local Fleet</h1>
          </div>
          <div class="type-sample">
            <span class="text-xs font-medium text-ink-tertiary">H2 / 36px / 700</span>
            <h2 class="text-4xl font-bold tracking-tight text-navy-900">Airport Delivery</h2>
          </div>
          <div class="type-sample">
            <span class="text-xs font-medium text-ink-tertiary">H3 / 24px / 600</span>
            <h3 class="text-2xl font-semibold text-navy-900">Choose your vehicle</h3>
          </div>
          <div class="type-sample">
            <span class="text-xs font-medium text-ink-tertiary">Body Lg / 18px / 400</span>
            <p class="text-lg text-ink leading-relaxed">Newer, well-maintained vehicles with airport delivery at MIA, FLL, and PBI. Straightforward pricing. Real local operator. No surprises.</p>
          </div>
          <div class="type-sample">
            <span class="text-xs font-medium text-ink-tertiary">Body / 16px / 400</span>
            <p class="text-base text-ink leading-relaxed">We meet you at the terminal at South Florida's three major airports. Every vehicle is professionally maintained and presented.</p>
          </div>
          <div class="type-sample">
            <span class="text-xs font-medium text-ink-tertiary">Small / 14px / 500</span>
            <p class="text-sm font-medium text-ink-secondary">Secondary text, captions, and metadata appear here.</p>
          </div>
          <div class="type-sample">
            <span class="text-xs font-medium text-ink-tertiary">Numeric styling / tabular</span>
            <p class="text-3xl font-bold text-navy-700 tabular-nums">$85<span class="text-lg font-normal text-ink-secondary">/day</span></p>
          </div>
        </div>
      </section>

      <!-- ════════ BUTTONS & LINKS ════════ -->
      <section class="preview-section">
        <SectionHeading title="Buttons & Links" level="h2" />

        <div class="mt-6 space-y-4">
          <div class="flex flex-wrap gap-3 items-center">
            <Button variant="primary" size="lg">Primary (Navy)</Button>
            <Button variant="secondary" size="lg">Secondary (Blue)</Button>
            <Button variant="outline" size="lg">Outline</Button>
            <Button variant="ghost" size="lg">Ghost</Button>
          </div>
          <div class="flex flex-wrap gap-3 items-center">
            <Button variant="primary" size="md">Primary MD</Button>
            <Button variant="secondary" size="md">Secondary MD</Button>
            <Button variant="outline" size="md">Outline MD</Button>
            <Button variant="ghost" size="md">Ghost MD</Button>
          </div>
          <div class="flex flex-wrap gap-3 items-center">
            <Button variant="primary" size="sm">Primary SM</Button>
            <Button variant="secondary" size="sm">Secondary SM</Button>
            <Button variant="outline" size="sm">Outline SM</Button>
            <Button variant="ghost" size="sm">Ghost SM</Button>
          </div>
          <div class="flex flex-wrap gap-4 items-center mt-2">
            <a href="#" class="text-blue-500 font-medium hover:underline">Text link</a>
            <a href="#" class="text-navy-700 font-medium hover:text-blue-500">Internal link →</a>
          </div>
        </div>
      </section>

      <!-- ════════ BADGES ════════ -->
      <section class="preview-section">
        <SectionHeading title="Badges & Chips" level="h2" />

        <div class="mt-6 space-y-4">
          <div class="flex flex-wrap gap-2">
            <span class="inline-block rounded-full bg-warning-light px-2.5 py-0.5 text-xs font-medium text-warning">Preview</span>
            <span class="inline-block rounded-full bg-success-light px-2.5 py-0.5 text-xs font-medium text-success">Available</span>
            <span class="inline-block rounded-full bg-blue-50 px-2.5 py-0.5 text-xs font-medium text-blue-700">Airport Delivery</span>
            <span class="inline-block rounded-full bg-navy-50 px-2.5 py-0.5 text-xs font-medium text-navy-700">Premium</span>
            <span class="inline-block rounded-full bg-coral-50 px-2.5 py-0.5 text-xs font-medium text-coral-700">New</span>
          </div>

          <div class="flex flex-wrap gap-2">
            <AirportChip code="MIA" name="Miami" />
            <AirportChip code="FLL" name="Fort Lauderdale" />
            <AirportChip code="PBI" name="Palm Beach" />
          </div>

          <div class="flex flex-wrap gap-2">
            <TrustBadge icon="M5 13l4 4L19 7" text="Verified vehicles" />
            <TrustBadge icon="M12 19l9 2-9-18-9 18 9-2zm0 0v-8" text="Airport delivery" />
