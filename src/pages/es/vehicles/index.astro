---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Header from "../../../components/base/Header.astro";
import Footer from "../../../components/base/Footer.astro";
import vehicles from "../../../data/vehicles.json";

const publishedVehicles = vehicles.filter(
  (v) => v.publication_status === "preview_only" || v.publication_status === "published"
);
---

<BaseLayout lang="es" title="Vehículos" description="Explora nuestra flota de vehículos para alquiler en el sur de Florida.">
  <Header />

  <main id="main-content" class="flex-1 bg-gray-50">
    <div class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h1 class="text-3xl font-bold text-gray-900 sm:text-4xl">Nuestra Flota</h1>
        <p class="mt-3 text-lg text-gray-500">
          Vehículos recientes y bien mantenidos para alquiler en el sur de Florida.
        </p>
      </div>

      {publishedVehicles.length === 0 ? (
        <div class="text-center py-16">
          <p class="text-gray-500 text-lg">Vehículos próximamente. Estamos preparando nuestra flota.</p>
        </div>
      ) : (
        <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {publishedVehicles.map((vehicle) => (
            <a
              href={`/es/vehicles/${vehicle.slug}/`}
              class="group bg-white rounded-xl border border-gray-200 overflow-hidden shadow-sm transition-all hover:border-brand hover:shadow-lg"
            >
              <div class="aspect-[4/3] bg-gray-200 flex items-center justify-center">
                {vehicle.hero_image ? (
                  <img src={vehicle.hero_image} alt={vehicle.name} class="w-full h-full object-cover" />
                ) : (
                  <span class="text-gray-400 text-sm">Foto del vehículo pendiente</span>
                )}
              </div>
              <div class="p-5">
                <h3 class="text-lg font-semibold text-gray-900 group-hover:text-brand">
                  {vehicle.name}
                </h3>
                <p class="text-sm text-gray-500 mt-1">{vehicle.tagline_es || vehicle.tagline_en}</p>
                <div class="mt-3 flex items-center gap-4 text-sm text-gray-500">
                  <span>🧑‍🤝‍🧑 {vehicle.passenger_capacity} pasajeros</span>
                  <span>🧳 {vehicle.luggage_large} maletas grandes</span>
                </div>
                <div class="mt-4 flex items-center justify-between">
                  <span class="text-lg font-semibold text-brand">
                    {vehicle.price_display_daily ? `Desde ${vehicle.price_display_daily}` : "Precio por Confirmar"}
                  </span>
                  {vehicle.publication_status === "preview_only" && (
                    <span class="text-xs text-yellow-600 bg-yellow-50 px-2 py-1 rounded">Vista previa</span>
                  )}
                </div>
              </div>
            </a>
          ))}
        </div>
      )}

      <div class="mt-12 text-center">
        <a
          href="/es/contact/"
          class="inline-flex items-center justify-center rounded-lg bg-brand px-6 py-3 text-base font-semibold text-white shadow-sm transition-colors hover:bg-brand-light"
        >
          ¿No encuentras lo que buscas? Contáctanos
        </a>
      </div>
    </div>
  </main>

  <Footer />
</BaseLayout>