---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Header from "../../../components/base/Header.astro";
import Footer from "../../../components/base/Footer.astro";
import vehicles from "../../../data/vehicles.json";
import { getFuelLabel, getBestForLabels } from "../../../config/labels";

export async function getStaticPaths() {
  return vehicles
    .filter((v) => v.publication_status === "preview_only" || v.publication_status === "published")
    .map((v) => ({
      params: { slug: v.slug },
      props: { vehicle: v },
    }));
}

const { vehicle } = Astro.props;

// Related vehicles: same fuel type or same passenger tier, excluding self
const relatedVehicles = vehicles
  .filter((v) =>
    v.slug !== vehicle.slug &&
    (v.publication_status === "preview_only" || v.publication_status === "published")
  )
  .filter((v) =>
    v.fuel_type === vehicle.fuel_type ||
    (v.passenger_capacity >= 7 && vehicle.passenger_capacity >= 7) ||
    (v.passenger_capacity <= 5 && vehicle.passenger_capacity <= 5)
  )
  .slice(0, 3);

const bestForLabels = getBestForLabels(vehicle.best_for || [], "es");
---

<BaseLayout lang="es" title={vehicle.name} description={vehicle.tagline_es || vehicle.tagline_en}>
  <Header />

  <main id="main-content" class="flex-1 bg-white">
    <div class="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8">
      <a href="/es/vehicles/" class="inline-flex items-center text-sm font-medium text-brand hover:underline">
        ← Volver a Vehículos
      </a>

      <div class="mt-6 grid grid-cols-1 gap-8 lg:grid-cols-2">
        <!-- Gallery area -->
        <div>
          <div class="aspect-[4/3] bg-gray-200 rounded-xl flex items-center justify-center">
            {vehicle.hero_image ? (
              <img src={vehicle.hero_image} alt={vehicle.name} class="w-full h-full object-cover rounded-xl" />
            ) : (
              <div class="text-center p-8">
                <p class="text-gray-400 text-sm">Foto pendiente</p>
                <p class="mt-2 text-xs text-gray-400">Próximamente fotografías reales del vehículo</p>
              </div>
            )}
          </div>

          {vehicle.gallery && vehicle.gallery.length > 0 && (
            <div class="mt-4 grid grid-cols-3 gap-3 sm:grid-cols-4">
              {vehicle.gallery.map((img) => (
                <div class="aspect-[4/3] bg-gray-100 rounded-lg overflow-hidden">
                  <img
                    src={img}
                    alt={`${vehicle.name} photo`}
                    class="w-full h-full object-cover"
                    loading="lazy"
                  />
                </div>
              ))}
            </div>
          )}
        </div>

        <!-- Vehicle info -->
        <div>
          <h1 class="text-3xl font-bold text-gray-900">{vehicle.name}</h1>
          {(vehicle.tagline_es || vehicle.tagline_en) && (
            <p class="mt-2 text-lg text-gray-500">{vehicle.tagline_es || vehicle.tagline_en}</p>
          )}

          <!-- Specs grid -->
          <div class="mt-6 grid grid-cols-2 gap-4 sm:grid-cols-3">
            <div class="rounded-lg bg-gray-50 p-3">
              <p class="text-xs text-gray-500">Pasajeros</p>
              <p class="text-xl font-semibold text-gray-900">{vehicle.passenger_capacity}</p>
            </div>
            <div class="rounded-lg bg-gray-50 p-3">
              <p class="text-xs text-gray-500">Combustible</p>
              <p class="text-sm font-semibold text-gray-900 pt-1">{getFuelLabel(vehicle.fuel_type, "es")}</p>
            </div>
            <div class="rounded-lg bg-gray-50 p-3">
              <p class="text-xs text-gray-500">Equipaje</p>
              <p class="text-xl font-semibold text-gray-900">{vehicle.luggage_large} grandes</p>
            </div>
            {vehicle.exterior_color && (
              <div class="rounded-lg bg-gray-50 p-3">
                <p class="text-xs text-gray-500">Exterior</p>
                <p class="text-sm font-semibold text-gray-900">{vehicle.exterior_color}</p>
              </div>
            )}
            {vehicle.interior_color && (
              <div class="rounded-lg bg-gray-50 p-3">
                <p class="text-xs text-gray-500">Interior</p>
                <p class="text-sm font-semibold text-gray-900">{vehicle.interior_color}</p>
              </div>
            )}
            {vehicle.drivetrain && (
              <div class="rounded-lg bg-gray-50 p-3">
                <p class="text-xs text-gray-500">Transmisión</p>
                <p class="text-sm font-semibold text-gray-900">{vehicle.drivetrain}</p>
              </div>
            )}
          </div>

          <!-- Best for -->
          {bestForLabels.length > 0 && (
            <div class="mt-6">
              <h2 class="text-lg font-semibold text-gray-900">Ideal Para</h2>
              <div class="mt-2 flex flex-wrap gap-2">
                {bestForLabels.map((label) => (
                  <span class="inline-flex items-center rounded-full bg-brand-pale px-3 py-1 text-sm font-medium text-brand-dark">
                    {label.es}
                  </span>
                ))}
              </div>
            </div>
          )}

          <!-- Pricing -->
          <div class="mt-6 rounded-xl border border-gray-200 p-4">
            <p class="text-sm text-gray-500">Desde</p>
            <p class="text-2xl font-bold text-brand">
              {vehicle.price_display_daily ? vehicle.price_display_daily : "Precio por Confirmar"}
            </p>
            <p class="text-xs text-gray-400 mt-1">El precio final se confirma al reservar</p>
          </div>

          <!-- Description -->
          {(vehicle.description_es || vehicle.description_en) && (
            <div class="mt-6 prose prose-sm prose-gray max-w-none">
              <h2 class="text-lg font-semibold text-gray-900">Sobre Este Vehículo</h2>
              <p>{vehicle.description_es || vehicle.description_en}</p>
            </div>
          )}

          <!-- Features -->
          {vehicle.key_features && vehicle.key_features.length > 0 && (
            <div class="mt-6">
              <h2 class="text-lg font-semibold text-gray-900">Características Principales</h2>
              <ul class="mt-3 grid grid-cols-1 sm:grid-cols-2 gap-2">
                {vehicle.key_features.map((feature) => (
                  <li class="flex items-center gap-2 text-sm text-gray-600">
                    <svg class="w-4 h-4 text-brand shrink-0" fill="currentColor" viewBox="0 0 20 20">
                      <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                    </svg>
                    {feature}
                  </li>
                ))}
              </ul>
            </div>
          )}

          <!-- Booking CTA -->
          {vehicle.book_path && (
            <div class="mt-6">
              <a
                href={vehicle.book_path}
                class="inline-flex items-center gap-2 rounded-lg bg-brand px-6 py-3 text-sm font-semibold text-white shadow-sm transition-colors hover:bg-brand-light"
              >
                Reservar ahora
              </a>
            </div>
          )}

          <!-- Secondary actions -->
          <div class="mt-4 flex flex-col sm:flex-row gap-3">
            <a href="/es/contact/" class="inline-flex items-center justify-center rounded-lg border border-gray-300 px-6 py-3 text-sm font-semibold text-gray-700 hover:border-brand hover:text-brand">
              Consultar Sobre Este Vehículo
            </a>
            <a href="/es/rental-requirements/" class="inline-flex items-center justify-center rounded-lg border border-gray-300 px-6 py-3 text-sm font-semibold text-gray-700 hover:border-brand hover:text-brand">
              Ver Requisitos
            </a>
          </div>

          {vehicle.publication_status === "preview_only" && (
            <div class="mt-4 rounded-lg bg-yellow-50 border border-yellow-300 p-3">
              <p class="text-xs text-yellow-800">
                ⓘ Vista previa — las especificaciones y precios mostrados aquí no son definitivos.
              </p>
            </div>
          )}
        </div>
      </div>

      <!-- Related vehicles -->
      {relatedVehicles.length > 0 && (
        <section class="mt-16 border-t border-gray-200 pt-12">
          <h2 class="text-2xl font-bold text-gray-900">Vehículos Similares</h2>
          <div class="mt-6 grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
            {relatedVehicles.map((rv) => (
              <a
                href={`/es/vehicles/${rv.slug}/`}
                class="group bg-white rounded-xl border border-gray-200 overflow-hidden shadow-sm transition-all hover:border-brand hover:shadow-lg"
              >
                <div class="aspect-[4/3] bg-gray-200 flex items-center justify-center">
                  {rv.hero_image ? (
                    <img src={rv.hero_image} alt={rv.name} class="w-full h-full object-cover" />
                  ) : (
                    <span class="text-gray-400 text-sm">Foto pendiente</span>
                  )}
                </div>
                <div class="p-4">
                  <h3 class="text-base font-semibold text-gray-900 group-hover:text-brand">{rv.name}</h3>
                  <p class="text-sm text-gray-500 mt-1 line-clamp-1">{rv.tagline_es || rv.tagline_en}</p>
                  <div class="mt-2 flex items-center gap-3 text-xs text-gray-500">
                    <span>🧑 {rv.passenger_capacity}</span>
                    <span>{getFuelLabel(rv.fuel_type, "es")}</span>
                  </div>
                </div>
              </a>
            ))}
          </div>
        </section>
      )}
    </div>
  </main>

  <Footer />
</BaseLayout>