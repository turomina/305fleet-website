---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Header from "../../../components/base/Header.astro";
import Footer from "../../../components/base/Footer.astro";
import vehicles from "../../../data/vehicles.json";
import { getFuelLabel } from "../../../config/labels";

export async function getStaticPaths() {
  return vehicles
    .filter(v => v.publication_status === "preview_only" || v.publication_status === "published")
    .map(v => ({ params: { slug: v.slug }, props: { vehicle: v } }));
}

const { vehicle } = Astro.props;

const luggageLabel = Number(vehicle.luggage_large) || Number(vehicle.luggage_small) || 0;
const bestFor = (vehicle.best_for_es && vehicle.best_for_es.length > 0) ? vehicle.best_for_es : (vehicle.best_for_en || ["Recogida en aeropuerto"]);

const relatedVehicles = vehicles
  .filter(v => v.slug !== vehicle.slug && (v.publication_status === "preview_only" || v.publication_status === "published"))
  .slice(0, 3);

const images = [vehicle.hero_image, ...(vehicle.gallery || []).slice(0, 5).map(g => g.src || g)].filter(Boolean);
---

<BaseLayout lang="es" title={vehicle.name}
  description={`${vehicle.tagline_es || vehicle.tagline_en} — ${vehicle.name}. ${vehicle.passenger_capacity} asientos, ${getFuelLabel(vehicle.fuel_type, "es")}. Alquiler directo con entrega en MIA, FLL y PBI.`}
>
  <Header />

  <main id="main-content" class="flex-1">
    <section class="relative bg-brand-900">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 lg:py-20">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-16 items-center">
          <div class="relative">
            {images[0] ? (
              <img src={images[0]} alt={vehicle.name} class="w-full aspect-[16/10] object-cover rounded-2xl shadow-xl" loading="eager" width="800" height="500" />
            ) : (
              <div class="w-full aspect-[16/10] bg-brand-800/50 rounded-2xl flex items-center justify-center text-white/30">Foto pendiente</div>
            )}
          </div>
          <div class="text-white">
            <p class="text-accent font-semibold tracking-[0.12em] uppercase text-sm mb-3">{vehicle.year} &middot; {vehicle.make}</p>
            <h1 class="text-3xl sm:text-4xl lg:text-5xl font-bold tracking-tight">{vehicle.name}</h1>
            <p class="mt-3 text-lg text-white/70 leading-relaxed">{vehicle.tagline_es || vehicle.tagline_en}</p>
            <div class="mt-6 flex flex-wrap gap-3">
              <span class="inline-flex items-center gap-1.5 px-4 py-2 rounded-full bg-white/10 text-sm">&#128103; {vehicle.passenger_capacity} asientos</span>
              <span class="inline-flex items-center gap-1.5 px-4 py-2 rounded-full bg-white/10 text-sm">&#128718; {luggageLabel} equipaje</span>
              <span class="inline-flex items-center gap-1.5 px-4 py-2 rounded-full bg-white/10 text-sm">{getFuelLabel(vehicle.fuel_type, "es")}</span>
            </div>
            <div class="mt-8 flex flex-col sm:flex-row gap-3">
              {vehicle.book_path ? (
                <a href={vehicle.book_path} class="btn btn-light btn-primary-lg">Reservar en Turo</a>
              ) : (
                <a href="/es/contact/" class="btn btn-light btn-primary-lg">Consultar</a>
              )}
              <a href="/es/how-it-works/" class="btn px-6 py-4 text-base font-semibold text-white border-2 border-white/30 rounded-lg hover:bg-white/10 transition-all">Cómo Funciona &rarr;</a>
            </div>
          </div>
        </div>
      </div>
    </section>

    {images.length > 1 && (
      <section class="py-8 bg-brand-50 border-b border-border">
        <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
          <div class="grid grid-cols-3 lg:grid-cols-6 gap-3">
            {images.slice(1, 7).map((src, i) => (
              <img src={src} alt={`${vehicle.name} vista ${i+1}`} class="w-full aspect-[4/3] object-cover rounded-lg" loading="lazy" width="400" height="300" />
            ))}
          </div>
        </div>
      </section>
    )}

    <section class="section bg-white">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
          <div>
            <p class="section-eyebrow">Ideal Para</p>
            <h2 class="section-title">Hecho para {bestFor[0]?.toLowerCase()}</h2>
            <ul class="mt-6 space-y-3">
              {bestFor.map((item) => (
                <li class="flex items-start gap-3">
                  <svg class="w-5 h-5 text-accent mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                  <span class="text-ink-secondary">{item}</span>
                </li>
              ))}
            </ul>
          </div>
          <div class="space-y-6">
            <div class="rounded-2xl bg-brand-50 p-8">
              <h3 class="text-lg font-semibold text-ink">Comodidad</h3>
              <p class="mt-2 text-ink-secondary">Espacio para hasta {vehicle.passenger_capacity} pasajeros con amplio espacio para piernas y control de clima.</p>
            </div>
            <div class="rounded-2xl bg-brand-50 p-8">
              <h3 class="text-lg font-semibold text-ink">Equipaje</h3>
              <p class="mt-2 text-ink-secondary">Capacidad para {vehicle.luggage_large || "múltiples"} maletas grandes — espacio suficiente para viajes al aeropuerto.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="section bg-brand-50">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <h2 class="text-3xl font-bold text-ink mb-8">Especificaciones</h2>
        <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-4">
          {[
            { label: "Año", value: vehicle.year },
            { label: "Marca", value: vehicle.make },
            { label: "Modelo", value: vehicle.model },
            { label: "Combustible", value: getFuelLabel(vehicle.fuel_type, "es") },
            { label: "Asientos", value: vehicle.passenger_capacity },
            { label: "Equipaje", value: `${vehicle.luggage_large || "-"} grande` },
          ].filter(s => s.value).map(spec => (
            <div class="bg-white rounded-xl p-6 text-center">
              <p class="text-2xl font-bold text-ink">{spec.value}</p>
              <p class="text-xs text-ink-tertiary uppercase tracking-wider mt-1">{spec.label}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="section bg-white">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <h2 class="text-3xl font-bold text-ink text-center mb-3">Entrega en Aeropuerto</h2>
        <p class="text-center text-ink-secondary max-w-xl mx-auto mb-10">
          Recoja su {vehicle.name} en MIA, FLL o PBI. Entrega sin contacto — ubicación exacta enviada de forma privada.
        </p>
        <div class="grid grid-cols-1 gap-4 sm:grid-cols-3">
          {["MIA", "FLL", "PBI"].map(code => (
            <a href={`/es/locations/${code === "MIA" ? "miami-international-airport" : code === "FLL" ? "fort-lauderdale-airport" : "palm-beach-airport"}/`} class="card card-padded text-center group">
              <div class="text-3xl font-bold text-accent mb-2">{code}</div>
              <p class="text-sm text-ink-secondary">Recogida sin contacto disponible</p>
              <span class="mt-3 inline-block text-xs font-medium text-accent">Detalles &rarr;</span>
            </a>
          ))}
        </div>
        <p class="mt-4 text-xs text-ink-tertiary text-center">Los cargos de estacionamiento son responsabilidad del arrendatario — divulgados en los términos de reservación.</p>
      </div>
    </section>

    {relatedVehicles.length > 0 && (
      <section class="section bg-brand-50">
        <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
          <h2 class="text-3xl font-bold text-ink text-center">Vehículos Relacionados</h2>
          <div class="mt-8 grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
            {relatedVehicles.map(rv => (
              <a href={`/es/vehicles/${rv.slug}/`} class="card group">
                <div class="aspect-[16/10] bg-brand-100 overflow-hidden">
                  {rv.hero_image ? (
                    <img src={rv.hero_image} alt={rv.name} class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-[1.04]" loading="lazy" width="600" height="375" />
                  ) : (
                    <div class="w-full h-full flex items-center justify-center text-ink-tertiary text-sm">Foto pendiente</div>
                  )}
                </div>
                <div class="p-5">
                  <h3 class="font-semibold text-ink">{rv.name}</h3>
                  <div class="mt-2 flex gap-2"><span class="chip text-xs">{rv.passenger_capacity} asientos</span><span class="chip text-xs">{getFuelLabel(rv.fuel_type, "es")}</span></div>
                </div>
              </a>
            ))}
          </div>
        </div>
      </section>
    )}

    <section class="section gradient-brand text-white text-center">
      <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
        <h2 class="text-4xl font-bold tracking-tight">¿Listo para conducir el {vehicle.name}?</h2>
        <div class="mt-6">
          {vehicle.book_path ? (
            <a href={vehicle.book_path} class="btn btn-light btn-primary-lg">Reservar en Turo</a>
          ) : (
            <a href="/es/contact/" class="btn btn-light btn-primary-lg">Consultar</a>
          )}
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>