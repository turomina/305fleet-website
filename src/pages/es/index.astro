---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/base/Header.astro";
import Footer from "../../components/base/Footer.astro";
import { SITE, BENEFITS } from "../../config/site";
---

<BaseLayout lang="es" title="305 Fleet — Alquiler de Vehículos en el Sur de Florida">
  <Header />

  <main id="main-content" class="flex-1">
    <!-- Hero Section -->
    <section class="relative bg-brand-dark text-white overflow-hidden">
      <div class="absolute inset-0 bg-gradient-to-br from-brand-dark via-brand to-brand-light opacity-90"></div>
      <div class="relative mx-auto max-w-7xl px-4 py-20 sm:px-6 lg:px-8 lg:py-28">
        <div class="max-w-2xl">
          <h1 class="text-4xl font-bold tracking-tight sm:text-5xl lg:text-6xl">
            Flota Local del Sur de Florida
          </h1>
          <p class="mt-6 text-lg text-gray-200 sm:text-xl">
            Vehículos recientes y bien mantenidos con entrega en aeropuerto en MIA, FLL y PBI.
            Precios transparentes. Operador local real. Sin sorpresas.
          </p>
          <div class="mt-8 flex flex-col sm:flex-row gap-4">
            <a
              href="/es/vehicles/"
              class="inline-flex items-center justify-center rounded-lg bg-white px-8 py-4 text-base font-semibold text-brand shadow-lg transition-colors hover:bg-gray-100"
            >
              Ver Vehículos
            </a>
            <a
              href="/es/how-it-works/"
              class="inline-flex items-center justify-center rounded-lg border-2 border-white/80 px-8 py-4 text-base font-semibold text-white transition-colors hover:bg-white/10"
            >
              Cómo Funciona
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- Benefit Strip -->
    <section class="bg-white border-b border-gray-200">
      <div class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8">
        <div class="grid grid-cols-2 gap-6 lg:grid-cols-4 lg:gap-8">
          {BENEFITS.map((benefit) => (
            <div class="text-center">
              <div class="mx-auto mb-3 flex h-12 w-12 items-center justify-center rounded-full bg-brand-pale">
                <svg class="h-6 w-6 text-brand" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  {benefit.icon === "plane" && (
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8" />
                  )}
                  {benefit.icon === "car" && (
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 17a2 2 0 11-4 0 2 2 0 014 0zM19 17a2 2 0 11-4 0 2 2 0 014 0z" />
                  )}
                  {benefit.icon === "phone" && (
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                  )}
                  {benefit.icon === "star" && (
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z" />
                  )}
                </svg>
              </div>
              <h3 class="text-sm font-semibold text-gray-900 lg:text-base">
                {benefit.icon === "plane" ? "Entrega en Aeropuerto" : benefit.icon === "car" ? "Flota Reciente" : benefit.icon === "phone" ? "Operador Real" : "Confianza en Turo"}
              </h3>
              <p class="mt-1 text-xs text-gray-500 lg:text-sm">
                {benefit.icon === "plane" ? "MIA · FLL · PBI — te esperamos en la terminal" : benefit.icon === "car" ? "Vehículos bien mantenidos, presentación profesional" : benefit.icon === "phone" ? "Contacto directo con un equipo local del sur de Florida" : "Reputación establecida — ahora reservas directas"}
              </p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Featured Vehicles (Placeholder) -->
    <section class="bg-gray-50 py-16 lg:py-20">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-12">
          <h2 class="text-3xl font-bold text-gray-900">Nuestra Flota</h2>
          <p class="mt-3 text-lg text-gray-500">
            Vehículos reales, fotos reales — próximamente.
          </p>
        </div>

        <!-- Vehicle cards placeholder -->
        <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {[1, 2, 3].map((i) => (
            <div class="bg-white rounded-xl border border-gray-200 overflow-hidden shadow-sm">
              <div class="aspect-[4/3] bg-gray-200 flex items-center justify-center">
                <span class="text-gray-400 text-sm">Foto del vehículo pendiente</span>
              </div>
              <div class="p-5">
                <h3 class="text-lg font-semibold text-gray-900">Vehículo {i}</h3>
                <p class="text-sm text-gray-500 mt-1">
                  Año · Marca · Modelo · Versión
                </p>
                <div class="mt-3 flex items-center gap-4 text-sm text-gray-500">
                  <span>🧑‍🤝‍🧑 5 pasajeros</span>
                  <span>🧳 2 maletas grandes</span>
                </div>
                <div class="mt-4 flex items-center justify-between">
                  <span class="text-lg font-semibold text-brand">Precio por Confirmar</span>
                  <span class="text-sm text-gray-400">Próximamente</span>
                </div>
              </div>
            </div>
          ))}
        </div>

        <div class="mt-10 text-center">
          <a
            href="/es/vehicles/"
            class="inline-flex items-center justify-center rounded-lg border-2 border-brand px-6 py-3 text-base font-semibold text-brand transition-colors hover:bg-brand hover:text-white"
          >
            Ver Todos los Vehículos →
          </a>
        </div>
      </div>
    </section>

    <!-- Airport Coverage -->
    <section class="bg-white py-16 lg:py-20 border-b border-gray-200">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-10">
          <h2 class="text-3xl font-bold text-gray-900">Entrega en Aeropuerto</h2>
          <p class="mt-3 text-lg text-gray-500">
            Te esperamos en la terminal de los tres principales aeropuertos del sur de Florida.
          </p>
        </div>
        <div class="grid grid-cols-1 gap-6 md:grid-cols-3">
          {[
            { code: "MIA", name: "Miami International", city: "Miami", slug: "miami-international-airport" },
            { code: "FLL", name: "Fort Lauderdale-Hollywood International", city: "Fort Lauderdale", slug: "fort-lauderdale-airport" },
            { code: "PBI", name: "Palm Beach International", city: "Palm Beach", slug: "palm-beach-airport" },
          ].map((airport) => (
            <a
              href={`/es/locations/${airport.slug}/`}
              class="group rounded-xl border border-gray-200 p-6 transition-all hover:border-brand hover:shadow-lg"
            >
              <div class="text-3xl font-bold text-brand">{airport.code}</div>
              <h3 class="mt-2 text-lg font-semibold text-gray-900 group-hover:text-brand">
                {airport.name}
              </h3>
              <p class="mt-1 text-sm text-gray-500">{airport.city}, FL</p>
              <p class="mt-3 text-sm font-medium text-brand group-hover:underline">
                Ver detalles del aeropuerto →
              </p>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- How It Works (preview) -->
    <section class="bg-brand-pale py-16 lg:py-20">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-10">
          <h2 class="text-3xl font-bold text-gray-900">Cómo Funciona</h2>
          <p class="mt-3 text-lg text-gray-600">Alquilar con 305 Fleet es simple.</p>
        </div>
        <div class="grid grid-cols-1 gap-8 md:grid-cols-4">
          {[
            { step: "1", title: "Ver Vehículos", desc: "Elige entre nuestra flota de vehículos recientes y bien mantenidos." },
            { step: "2", title: "Consultar Disponibilidad", desc: "Selecciona tus fechas y ubicación de recogida." },
            { step: "3", title: "Confirmar Reserva", desc: "Completa la verificación de conductor y selección de seguro." },
            { step: "4", title: "Recoger y Conducir", desc: "Encuéntranos en el aeropuerto o ubicación designada. Y a conducir." },
          ].map((item) => (
            <div class="text-center">
              <div class="mx-auto mb-4 flex h-12 w-12 items-center justify-center rounded-full bg-brand text-white font-bold text-lg">
                {item.step}
              </div>
              <h3 class="text-base font-semibold text-gray-900">{item.title}</h3>
              <p class="mt-2 text-sm text-gray-600">{item.desc}</p>
            </div>
          ))}
        </div>
        <div class="mt-10 text-center">
          <a
            href="/es/how-it-works/"
            class="inline-flex items-center justify-center text-base font-semibold text-brand hover:underline"
          >
            Detalles completos del proceso →
          </a>
        </div>
      </div>
    </section>

    <!-- Reviews placeholder -->
    <section class="bg-white py-16 lg:py-20 border-b border-gray-200">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="text-center">
          <h2 class="text-3xl font-bold text-gray-900">La Confianza de los Viajeros del Sur de Florida</h2>
          <p class="mt-3 text-lg text-gray-500">
            Reseñas de nuestros clientes de Turo — pronto disponibles aquí directamente.
          </p>
          <div class="mt-6 inline-flex items-center gap-2">
            <div class="flex">
              {[1, 2, 3, 4, 5].map(() => (
                <svg class="h-6 w-6 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.799-2.034a1 1 0 00-1.176 0l-2.799 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                </svg>
              ))}
            </div>
            <span class="text-lg font-semibold text-gray-900">5.0</span>
            <span class="text-gray-500">en Turo</span>
          </div>
        </div>
      </div>
    </section>

    <!-- Final CTA -->
    <section class="bg-brand text-white py-16 lg:py-20">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 text-center">
        <h2 class="text-3xl font-bold sm:text-4xl">¿Listo para conducir?</h2>
        <p class="mt-3 text-lg text-gray-200">
          Explora nuestra flota o contáctanos — estamos aquí para ayudarte.
        </p>
        <div class="mt-8 flex flex-col sm:flex-row justify-center gap-4">
          <a
            href="/es/vehicles/"
            class="inline-flex items-center justify-center rounded-lg bg-white px-8 py-4 text-base font-semibold text-brand shadow-lg transition-colors hover:bg-gray-100"
          >
            Ver Vehículos
          </a>
          <a
            href="/es/contact/"
            class="inline-flex items-center justify-center rounded-lg border-2 border-white/80 px-8 py-4 text-base font-semibold text-white transition-colors hover:bg-white/10"
          >
            Contáctanos
          </a>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>