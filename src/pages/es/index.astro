---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/base/Header.astro";
import Footer from "../../components/base/Footer.astro";
import vehicles from "../../data/vehicles.json";
import { getFuelLabel } from "../../config/labels";

const allVehicles = vehicles.filter(v => v.publication_status === "preview_only" || v.publication_status === "published");
const featuredVehicles = allVehicles.slice(0, 3);

const airports = [
  { code: "MIA", name: "Miami International", slug: "miami-international-airport", desc: "Garajes Dolphin, Flamingo e Ibis — ubicación exacta enviada de forma privada" },
  { code: "FLL", name: "Fort Lauderdale", slug: "fort-lauderdale-airport", desc: "Cypress Garage, Nivel 7, Zona 7NN — ubicación exacta enviada de forma privada" },
  { code: "PBI", name: "Palm Beach", slug: "palm-beach-airport", desc: "Long-Term Garage 1 o 2 — Premium Parking disponible por solicitud" },
];

const steps = [
  { num: "1", title: "Elija Su Vehículo", desc: "Explore nuestra flota de vehículos recientes con fotos reales y especificaciones completas." },
  { num: "2", title: "Seleccione Fechas y Aeropuerto", desc: "Elija MIA, FLL o PBI. Seleccione sus fechas de alquiler. Confirmamos disponibilidad." },
  { num: "3", title: "Complete la Reservación", desc: "Proporcione la información necesaria para confirmar su reservación directa de forma segura." },
  { num: "4", title: "Recoja y Conduzca", desc: "Reciba instrucciones privadas de ubicación. Recogida sin contacto. Disfrute del sur de Florida." },
];
---

<BaseLayout lang="es" title="Alquiler Directo de Vehículos en el Sur de Florida" description="Alquiler directo de vehículos en el sur de Florida. Flota reciente, entrega en MIA, FLL y PBI, recogida sin contacto. Reserve con un operador local.">
  <Header />

  <main id="main-content" class="flex-1">
    <!-- Hero -->
    <section class="relative min-h-[90vh] flex items-center bg-brand-900 overflow-hidden">
      <div class="absolute inset-0">
        <img src="/images/generated/hero-bg.png" alt="" class="w-full h-full object-cover" loading="eager" />
      </div>
      <div class="absolute inset-0 gradient-hero-overlay"></div>

      <div class="relative z-10 mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-20 lg:py-28 w-full">
        <div class="max-w-3xl">
          <p class="text-accent font-semibold tracking-[0.12em] uppercase text-sm mb-6 fade-in">Alquiler Directo — Sur de Florida</p>
          <h1 class="text-5xl sm:text-6xl lg:text-7xl font-bold tracking-tight text-white leading-[1.08]">
            Vehículos premium.<br class="hidden sm:block" />Recogida sin contacto.<br class="hidden sm:block" />Servicio local real.
          </h1>
          <p class="mt-6 text-lg sm:text-xl text-white/80 leading-relaxed max-w-xl">
            Alquiler directo de un operador de flota del sur de Florida. Entrega en MIA, FLL y PBI.
            Sin mostradores, sin autobuses — solo un vehículo limpio y listo cuando llegue.
          </p>
          <div class="mt-10 flex flex-col sm:flex-row gap-4">
            <a href="/es/vehicles/" class="btn btn-light btn-primary-lg">Reservar ahora</a>
            <a href="/es/how-it-works/" class="btn px-6 py-4 text-base font-semibold text-white border-2 border-white/30 rounded-lg hover:bg-white/10 transition-all">Cómo Funciona</a>
          </div>
          <div class="mt-12 flex items-center gap-6 text-sm text-white/60">
            <span>✓ MIA · FLL · PBI</span>
            <span>✓ Entrega sin contacto</span>
            <span>✓ Operador local</span>
          </div>
        </div>
      </div>
    </section>

    <!-- Fleet -->
    <section class="section bg-surface">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="max-w-2xl">
          <p class="section-eyebrow">Nuestra Flota</p>
          <h2 class="section-title">{allVehicles.length} vehículos. Un estándar.</h2>
          <p class="section-subtitle">Cada vehículo es reciente, bien mantenido y presentado profesionalmente.</p>
        </div>
        <div class="mt-12 grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {featuredVehicles.map(v => (
            <a href={`/es/vehicles/${v.slug}/`} class="card group">
              <div class="aspect-[16/10] bg-brand-100 overflow-hidden">
                {v.hero_image ? (
                  <img src={v.hero_image} alt={v.name} class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-[1.04]" loading="lazy" width="800" height="500" />
                ) : (
                  <div class="w-full h-full flex items-center justify-center text-ink-tertiary">Foto pendiente</div>
                )}
              </div>
              <div class="p-6">
                <div class="flex items-start justify-between gap-3">
                  <div>
                    <h3 class="text-xl font-semibold text-ink">{v.name}</h3>
                    <p class="text-sm text-ink-secondary mt-1 line-clamp-1">{v.tagline_es || v.tagline_en}</p>
                  </div>
                  {v.book_path && <span class="btn btn-primary text-xs px-3 py-1.5">Reservar</span>}
                </div>
                <div class="mt-4 flex flex-wrap items-center gap-2">
                  <span class="chip">&#128103; {v.passenger_capacity}</span>
                  <span class="chip">&#128718; {v.luggage_large}</span>
                  <span class="chip">{getFuelLabel(v.fuel_type, "es")}</span>
                </div>
              </div>
            </a>
          ))}
        </div>
        <div class="mt-10 text-center">
          <a href="/es/vehicles/" class="btn btn-secondary">Ver {allVehicles.length} Vehículos &rarr;</a>
        </div>
      </div>
    </section>

    <!-- Airports -->
    <section class="section relative bg-brand-900 overflow-hidden">
      <div class="absolute inset-0">
        <img src="/images/generated/airport-visual.png" alt="" class="w-full h-full object-cover opacity-30" loading="lazy" />
      </div>
      <div class="absolute inset-0 bg-gradient-to-b from-brand-900/90 via-brand-900/70 to-brand-900/90"></div>
      <div class="relative z-10 mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="text-center max-w-2xl mx-auto">
          <p class="text-accent font-semibold tracking-[0.12em] uppercase text-sm mb-4">Entrega en Aeropuerto</p>
          <h2 class="text-4xl font-bold tracking-tight text-white">MIA · FLL · PBI</h2>
          <p class="mt-4 text-lg text-white/70">Recogida sin contacto en los tres aeropuertos. Ubicación exacta enviada de forma privada.</p>
        </div>
        <div class="mt-12 grid grid-cols-1 gap-6 md:grid-cols-3">
          {airports.map(a => (
            <a href={`/es/locations/${a.slug}/`} class="block rounded-2xl bg-white/10 backdrop-blur-sm border border-white/10 p-8 hover:bg-white/15 transition-all group">
              <div class="text-5xl font-bold text-accent mb-3">{a.code}</div>
              <h3 class="text-xl font-semibold text-white">{a.name}</h3>
              <p class="mt-2 text-sm text-white/60">{a.desc}</p>
              <span class="mt-4 inline-flex items-center text-sm font-medium text-accent">Detalles &rarr;</span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- Steps -->
    <section class="section bg-brand-50">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="text-center max-w-2xl mx-auto">
          <p class="section-eyebrow">Cómo Funciona</p>
          <h2 class="section-title">Simple, directo, sin contacto</h2>
        </div>
        <div class="mt-12 grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-4">
          {steps.map(s => (
            <div class="rounded-2xl bg-white p-8 border border-border shadow-sm">
              <div class="text-5xl font-bold text-brand-100 mb-4">{s.num}</div>
              <h3 class="text-lg font-semibold text-ink mb-2">{s.title}</h3>
              <p class="text-sm text-ink-secondary">{s.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Final CTA -->
    <section class="section gradient-brand text-white text-center">
      <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
        <h2 class="text-4xl sm:text-5xl font-bold tracking-tight">¿Listo para conducir?</h2>
        <p class="mt-4 text-xl text-white/80">Explore nuestra flota. Entrega en MIA, FLL y PBI.</p>
        <div class="mt-8 flex flex-col sm:flex-row justify-center gap-4">
          <a href="/es/vehicles/" class="btn btn-light btn-primary-lg">Reservar ahora</a>
          <a href="/es/contact/" class="btn px-6 py-4 text-base font-semibold text-white border-2 border-white/30 rounded-lg hover:bg-white/10 transition-all">Contáctanos</a>
        </div>
      </div>
    </section>
  </main>

  <Footer />
  <style>
    @keyframes fadeIn { from { opacity: 0; transform: translateY(12px); } to { opacity: 1; transform: translateY(0); } }
    .fade-in { animation: fadeIn 0.8s cubic-bezier(0.19, 1, 0.22, 1) both; }
    @media (prefers-reduced-motion: reduce) { .fade-in { animation: none; } }
  </style>
</BaseLayout>