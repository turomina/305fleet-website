---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/base/Header.astro";
import Footer from "../components/base/Footer.astro";
---

<BaseLayout
  title="Contact"
  description="Contact 305 Fleet — South Florida vehicle rentals. Reach us by phone, WhatsApp, or email."
>
  <Header />

  <main id="main-content" class="flex-1 bg-white">
    <div class="mx-auto max-w-3xl px-4 py-12 sm:px-6 lg:px-8 lg:py-16">
      <h1 class="text-3xl font-bold text-gray-900">Contact 305 Fleet</h1>
      <p class="mt-3 text-lg text-gray-500">
        Questions about a rental, vehicle availability, or airport pickup? We're here to help.
      </p>

      <div class="mt-8 grid grid-cols-1 gap-6 sm:grid-cols-3">
        <a href="tel:" class="rounded-lg border border-gray-200 p-6 text-center hover:border-brand hover:shadow-md transition-all">
          <div class="mx-auto mb-3 flex h-12 w-12 items-center justify-center rounded-full bg-brand-pale">
            <svg class="h-6 w-6 text-brand" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
          </div>
          <h3 class="text-sm font-semibold text-gray-900">Phone</h3>
          <p class="mt-1 text-sm text-gray-500">Coming soon</p>
        </a>

        <a href="#" class="rounded-lg border border-gray-200 p-6 text-center hover:border-brand hover:shadow-md transition-all">
          <div class="mx-auto mb-3 flex h-12 w-12 items-center justify-center rounded-full bg-green-50">
            <svg class="h-6 w-6 text-green-600" fill="currentColor" viewBox="0 0 24 24">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.148-.669-1.611-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347" />
            </svg>
          </div>
          <h3 class="text-sm font-semibold text-gray-900">WhatsApp</h3>
          <p class="mt-1 text-sm text-gray-500">Coming soon</p>
        </a>

        <a href="mailto:" class="rounded-lg border border-gray-200 p-6 text-center hover:border-brand hover:shadow-md transition-all">
          <div class="mx-auto mb-3 flex h-12 w-12 items-center justify-center rounded-full bg-brand-pale">
            <svg class="h-6 w-6 text-brand" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
          </div>
          <h3 class="text-sm font-semibold text-gray-900">Email</h3>
          <p class="mt-1 text-sm text-gray-500">Coming soon</p>
        </a>
      </div>

      <div class="mt-8 rounded-lg bg-brand-pale p-6">
        <p class="text-sm text-brand-dark">
          ⓘ Contact information will be updated soon. For immediate assistance, reach us through our website.
        </p>
      </div>
    </div>
  </main>

  <Footer />
</BaseLayout>