---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/base/Header.astro";
import Footer from "../components/base/Footer.astro";
import { SITE } from "../config/site";
---

<BaseLayout
  title="Contact"
  description="Get in touch with 305 Fleet — South Florida direct vehicle rentals. Contactless airport pickup from designated parking at MIA, FLL, and PBI."
>
  <Header />

  <main id="main-content" class="flex-1">
    <section class="section-sm gradient-dark text-white">
      <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
        <p class="text-accent font-semibold tracking-[0.12em] uppercase text-sm mb-4">Contact</p>
        <h1 class="text-4xl sm:text-5xl font-bold tracking-tight">Let's talk.</h1>
        <p class="mt-4 text-lg text-white/70 max-w-xl">Questions about a rental, vehicle availability, or airport pickup? We're here.</p>
      </div>
    </section>

    <section class="section bg-surface">
      <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
        <div class="rounded-2xl bg-brand-50 p-8 md:p-12">
          <h2 class="text-2xl font-bold text-ink mb-4">Contact 305 Fleet</h2>
          <p class="text-ink-secondary leading-relaxed mb-6">
            Direct communication channels are being finalized. In the meantime, browse our fleet online
            and learn how our contactless airport pickup works.
          </p>
          <ul class="space-y-3 mb-8">
            {[
              "Direct communication with a local South Florida operator",
              "English and Spanish support",
              "Airport pickup and return questions welcome",
              "Reservation details confirmed before pickup",
            ].map(item => (
              <li class="flex items-start gap-2">
                <svg class="w-5 h-5 text-accent mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                <span class="text-sm text-ink-secondary">{item}</span>
              </li>
            ))}
          </ul>
          <div class="flex flex-col sm:flex-row gap-4">
            <a href="/vehicles/" class="btn btn-primary">Browse Fleet</a>
            <a href="/how-it-works/" class="btn btn-secondary">How It Works</a>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>