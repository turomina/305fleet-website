---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/base/Header.astro";
import Footer from "../components/base/Footer.astro";
import { SITE } from "../config/site";
---

<BaseLayout
  title="Contact 305 Fleet"
  description="Get in touch with 305 Fleet — South Florida direct vehicle rentals. Airport delivery at MIA, FLL, and PBI."
>
  <Header />

  <main id="main-content" class="flex-1">
    <section class="section-sm gradient-dark text-white">
      <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
        <p class="text-accent font-semibold tracking-[0.12em] uppercase text-sm mb-4">Contact</p>
        <h1 class="text-4xl sm:text-5xl font-bold tracking-tight">Let's talk.</h1>
        <p class="mt-4 text-lg text-white/70 max-w-xl">Questions about a rental, vehicle availability, or airport pickup? We're here.</p>
      </div>
    </section>

    <section class="section bg-surface">
      <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 gap-8 md:grid-cols-2">
          <!-- Contact channels -->
          <div class="space-y-6">
            {[
              { icon: "phone", title: "Phone", value: SITE.phone || "Contact details coming soon", href: SITE.phone ? `tel:${SITE.phone}` : "#", available: !!SITE.phone, accent: false },
              { icon: "whatsapp", title: "WhatsApp", value: SITE.whatsapp || "Coming soon", href: SITE.whatsapp ? `https://wa.me/${SITE.whatsapp}` : "#", available: !!SITE.whatsapp, accent: true },
              { icon: "email", title: "Email", value: SITE.email || "Coming soon", href: SITE.email ? `mailto:${SITE.email}` : "#", available: !!SITE.email, accent: false },
            ].map(ch => (
              <a href={ch.href} class={`block rounded-2xl p-8 border transition-all duration-300 ${ch.available ? 'border-border hover:border-brand hover:shadow-lg cursor-pointer' : 'border-border cursor-default opacity-60'}`}>
                <div class={`inline-flex h-12 w-12 items-center justify-center rounded-xl mb-4 ${ch.accent ? 'bg-accent/10 text-accent' : 'bg-brand-50 text-brand'}`}>
                  {ch.icon === "phone" && <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>}
                  {ch.icon === "whatsapp" && <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.148-.669-1.611-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347"/></svg>}
                  {ch.icon === "email" && <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>}
                </div>
                <h3 class="text-lg font-semibold text-ink mb-1">{ch.title}</h3>
                <p class="text-ink-secondary">{ch.value}</p>
              </a>
            ))}
          </div>

          <!-- Info panel -->
          <div class="rounded-2xl bg-brand-50 p-8 flex flex-col justify-center">
            <h2 class="text-2xl font-bold text-ink mb-4">What to expect</h2>
            <ul class="space-y-3">
              {[
                "Direct communication with a local South Florida team",
                "English and Spanish support",
                "Quick response during business hours",
                "Honest answers — no call-center scripts",
                "Airport pickup and return questions welcome",
              ].map(item => (
                <li class="flex items-start gap-2">
                  <svg class="w-5 h-5 text-accent mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                  <span class="text-sm text-ink-secondary">{item}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>

        <div class="mt-8 text-center">
          <a href="/vehicles/" class="btn btn-primary btn-primary-lg">Book Now</a>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>