---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/base/Header.astro";
import Footer from "../components/base/Footer.astro";
---

<BaseLayout
  title="About"
  description="305 Fleet is a locally operated South Florida vehicle fleet serving Miami, Fort Lauderdale, and Palm Beach with newer vehicles and airport delivery."
>
  <Header />

  <main id="main-content" class="flex-1 bg-white">
    <div class="mx-auto max-w-3xl px-4 py-12 sm:px-6 lg:px-8 lg:py-16">
      <h1 class="text-3xl font-bold text-gray-900">About 305 Fleet</h1>

      <div class="mt-6 prose prose-lg prose-gray max-w-none">
        <p>
          305 Fleet is a locally operated South Florida vehicle fleet serving Miami, Fort Lauderdale,
          Palm Beach, and surrounding areas. We offer newer, well-maintained vehicles with straightforward
          pricing, airport delivery, and responsive personal service.
        </p>

        <h2>Our Approach</h2>
        <p>
          We're not a faceless national chain or a stereotypical Miami exotic-car rental. We're a real
          local operator who knows South Florida — the airports, the traffic, the neighborhoods, and
          the roads. We believe in transparent pricing, clean vehicles, and treating customers like
          neighbors, not transactions.
        </p>

        <h2>What We Offer</h2>
        <ul>
          <li>Family vehicles with real passenger and luggage capacity</li>
          <li>Business rentals — professional vehicles, quick pickup</li>
          <li>Premium SUV options for special occasions</li>
          <li>Electric and hybrid vehicles for eco-conscious travelers</li>
          <li>Daily, weekly, and monthly rental options</li>
          <li>Airport delivery at MIA, FLL, and PBI</li>
        </ul>

        <h2>Our Standards</h2>
        <p>
          Every vehicle in our fleet is newer, well-maintained, and professionally presented.
          What you see in the photos is what you drive. No surprises, no "or similar" substitutions.
        </p>

        <div class="mt-8 rounded-lg bg-brand-pale p-6">
          <p class="text-brand-dark font-medium">
            Have questions? We're here to help.
          </p>
          <a href="/contact/" class="mt-2 inline-flex items-center text-brand font-semibold hover:underline">
            Get in touch →
          </a>
        </div>
      </div>
    </div>
  </main>

  <Footer />
</BaseLayout>