---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/base/Header.astro";
import Footer from "../../components/base/Footer.astro";
import vehicles from "../../data/vehicles.json";
import { getFuelLabel } from "../../config/labels";

const allVehicles = vehicles.filter(v => v.publication_status === "preview_only" || v.publication_status === "published");
---

<BaseLayout
  title="Our Fleet"
  description="Browse the 305 Fleet catalog — newer, well-maintained vehicles for direct rental in South Florida. Airport delivery at MIA, FLL, and PBI."
>
  <Header />

  <main id="main-content" class="flex-1">
    <!-- Hero -->
    <section class="section-sm gradient-dark text-white">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <p class="text-accent font-semibold tracking-[0.12em] uppercase text-sm mb-4">Fleet Catalog</p>
        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold tracking-tight">{allVehicles.length} vehicles. One standard.</h1>
        <p class="mt-4 text-lg text-white/70 max-w-2xl">
          Every vehicle is newer, well-maintained, and professionally presented.
          Airport delivery available at MIA, FLL, and PBI.
        </p>
      </div>
    </section>

    <!-- Fleet Grid -->
    <section class="section bg-surface">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        {allVehicles.length === 0 ? (
          <div class="text-center py-16">
            <p class="text-xl text-ink-secondary">No vehicles available. Check back soon.</p>
          </div>
        ) : (
          <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
            {allVehicles.map(v => (
              <a href={`/vehicles/${v.slug}/`} class="card group">
                <div class="aspect-[16/10] bg-brand-100 overflow-hidden">
                  {v.hero_image ? (
                    <img src={v.hero_image} alt={v.name} class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-[1.04]" loading="lazy" width="800" height="500" />
                  ) : (
                    <div class="w-full h-full flex items-center justify-center text-ink-tertiary text-sm">Photo pending</div>
                  )}
                </div>
                <div class="p-6">
                  <div class="flex items-start justify-between gap-3">
                    <div>
                      <h2 class="text-xl font-semibold text-ink group-hover:text-brand transition-colors">{v.name}</h2>
                      <p class="text-sm text-ink-secondary mt-1">{v.tagline_en}</p>
                    </div>
                    {v.book_path && (
                      <span class="btn btn-primary text-xs px-3 py-1.5 shrink-0">Book Now</span>
                    )}
                  </div>
                  <div class="mt-4 flex flex-wrap items-center gap-2">
                    <span class="chip">&#128103; {v.passenger_capacity}</span>
                    <span class="chip">&#128718; {v.luggage_large}</span>
                    <span class="chip">{getFuelLabel(v.fuel_type, "en")}</span>
                  </div>
                </div>
              </a>
            ))}
          </div>
        )}
      </div>
    </section>

    <!-- Bottom CTA -->
    <section class="section-sm bg-brand-50">
      <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 text-center">
        <h2 class="text-3xl font-bold text-ink">Not sure which vehicle?</h2>
        <p class="mt-3 text-ink-secondary">Our team can help you find the right vehicle for your trip.</p>
        <div class="mt-6">
          <a href="/contact/" class="btn btn-primary">Contact Us</a>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>