---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/base/Header.astro";
import Footer from "../../components/base/Footer.astro";
import vehicles from "../../data/vehicles.json";

export async function getStaticPaths() {
  return vehicles
    .filter((v) => v.publication_status === "preview_only" || v.publication_status === "published")
    .map((v) => ({
      params: { slug: v.slug },
      props: { vehicle: v },
    }));
}

const { vehicle } = Astro.props;
---

<BaseLayout
  title={vehicle.name}
  description={vehicle.tagline_en}
>
  <Header />

  <main id="main-content" class="flex-1 bg-white">
    <div class="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8">
      <!-- Back link -->
      <a href="/vehicles/" class="inline-flex items-center text-sm font-medium text-brand hover:underline">
        ← Back to Vehicles
      </a>

      <div class="mt-6 grid grid-cols-1 gap-8 lg:grid-cols-2">
        <!-- Gallery area -->
        <div>
          <div class="aspect-[4/3] bg-gray-200 rounded-xl flex items-center justify-center">
            {vehicle.hero_image ? (
              <img src={vehicle.hero_image} alt={vehicle.name} class="w-full h-full object-cover rounded-xl" />
            ) : (
              <div class="text-center p-8">
                <p class="text-gray-400 text-sm">Photo pending</p>
                <p class="mt-2 text-xs text-gray-400">Real vehicle photography coming soon</p>
              </div>
            )}
          </div>
        </div>

        <!-- Vehicle info -->
        <div>
          <h1 class="text-3xl font-bold text-gray-900">{vehicle.name}</h1>
          {vehicle.tagline_en && (
            <p class="mt-2 text-lg text-gray-500">{vehicle.tagline_en}</p>
          )}

          <!-- Specs grid -->
          <div class="mt-6 grid grid-cols-2 gap-4 sm:grid-cols-3">
            <div class="rounded-lg bg-gray-50 p-3">
              <p class="text-xs text-gray-500">Passengers</p>
              <p class="text-xl font-semibold text-gray-900">{vehicle.passenger_capacity}</p>
            </div>
            <div class="rounded-lg bg-gray-50 p-3">
              <p class="text-xs text-gray-500">Fuel</p>
              <p class="text-xl font-semibold text-gray-900">{vehicle.fuel_type}</p>
            </div>
            <div class="rounded-lg bg-gray-50 p-3">
              <p class="text-xs text-gray-500">Luggage</p>
              <p class="text-xl font-semibold text-gray-900">{vehicle.luggage_large} large</p>
            </div>
            {vehicle.exterior_color && (
              <div class="rounded-lg bg-gray-50 p-3">
                <p class="text-xs text-gray-500">Exterior</p>
                <p class="text-sm font-semibold text-gray-900">{vehicle.exterior_color}</p>
              </div>
            )}
            {vehicle.interior_color && (
              <div class="rounded-lg bg-gray-50 p-3">
                <p class="text-xs text-gray-500">Interior</p>
                <p class="text-sm font-semibold text-gray-900">{vehicle.interior_color}</p>
              </div>
            )}
            {vehicle.drivetrain && (
              <div class="rounded-lg bg-gray-50 p-3">
                <p class="text-xs text-gray-500">Drivetrain</p>
                <p class="text-sm font-semibold text-gray-900">{vehicle.drivetrain}</p>
              </div>
            )}
          </div>

          <!-- Pricing -->
          <div class="mt-6 rounded-xl border border-gray-200 p-4">
            <p class="text-sm text-gray-500">Starting from</p>
            <p class="text-2xl font-bold text-brand">
              {vehicle.price_display_daily ? vehicle.price_display_daily : "Pricing TBD"}
            </p>
            <p class="text-xs text-gray-400 mt-1">Final pricing confirmed at booking</p>
          </div>

          <!-- Description -->
          {vehicle.description_en && (
            <div class="mt-6 prose prose-sm prose-gray max-w-none">
              <h2 class="text-lg font-semibold text-gray-900">About This Vehicle</h2>
              <p>{vehicle.description_en}</p>
            </div>
          )}

          <!-- Features -->
          {vehicle.key_features && vehicle.key_features.length > 0 && (
            <div class="mt-6">
              <h2 class="text-lg font-semibold text-gray-900">Key Features</h2>
              <ul class="mt-3 grid grid-cols-1 sm:grid-cols-2 gap-2">
                {vehicle.key_features.map((feature) => (
                  <li class="flex items-center gap-2 text-sm text-gray-600">
                    <svg class="w-4 h-4 text-brand shrink-0" fill="currentColor" viewBox="0 0 20 20">
                      <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                    </svg>
                    {feature}
                  </li>
                ))}
              </ul>
            </div>
          )}

          <!-- Turo link -->
          {vehicle.turo_url && (
            <div class="mt-6">
              <a
                href={vehicle.turo_url}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-2 rounded-lg border border-gray-300 px-4 py-2 text-sm font-medium text-gray-700 hover:border-brand hover:text-brand"
              >
                View on Turo ↗
              </a>
            </div>
          )}

          <!-- Action -->
          <div class="mt-8 flex flex-col sm:flex-row gap-3">
            <a href="/contact/" class="inline-flex items-center justify-center rounded-lg bg-brand px-6 py-3 text-sm font-semibold text-white hover:bg-brand-light">
              Inquire About This Vehicle
            </a>
            <a href="/rental-requirements/" class="inline-flex items-center justify-center rounded-lg border border-gray-300 px-6 py-3 text-sm font-semibold text-gray-700 hover:border-brand hover:text-brand">
              View Requirements
            </a>
          </div>

          <!-- Publication status note -->
          {vehicle.publication_status === "preview_only" && (
            <div class="mt-4 rounded-lg bg-yellow-50 border border-yellow-300 p-3">
              <p class="text-xs text-yellow-800">
                ⓘ Preview — specifications and pricing shown here are not final.
              </p>
            </div>
          )}
        </div>
      </div>
    </div>
  </main>

  <Footer />
</BaseLayout>