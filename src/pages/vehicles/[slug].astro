---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/base/Header.astro";
import Footer from "../../components/base/Footer.astro";
import vehicles from "../../data/vehicles.json";
import { getFuelLabel } from "../../config/labels";

export async function getStaticPaths() {
  return vehicles
    .filter(v => v.publication_status === "preview_only" || v.publication_status === "published")
    .map(v => ({ params: { slug: v.slug }, props: { vehicle: v } }));
}

const { vehicle } = Astro.props;

const seatsLabel = Number(vehicle.passenger_capacity) === 1 ? "seat" : "seats";
const luggageLabel = Number(vehicle.luggage_large) || Number(vehicle.luggage_small) || 0;

const bestFor = (vehicle.best_for_en && vehicle.best_for_en.length > 0)
  ? vehicle.best_for_en
  : ["Airport pickup", "South Florida travel"];

const relatedVehicles = vehicles
  .filter(v => v.slug !== vehicle.slug && (v.publication_status === "preview_only" || v.publication_status === "published"))
  .slice(0, 3);

const images = [
  vehicle.hero_image,
  ...(vehicle.gallery || []).slice(0, 5).map(g => g.src || g),
].filter(Boolean);
---

<BaseLayout
  title={vehicle.name}
  description={`${vehicle.tagline_en} — ${vehicle.name}. ${vehicle.passenger_capacity} ${seatsLabel}, ${getFuelLabel(vehicle.fuel_type, "en")}. Direct rental with airport delivery at MIA, FLL, and PBI.`}
>
  <Header />

  <main id="main-content" class="flex-1">
    {/* Hero Gallery */}
    <section class="relative bg-brand-900">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 lg:py-20">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-16 items-center">
          {/* Image */}
          <div class="relative">
            {images[0] ? (
              <img
                src={images[0]}
                alt={vehicle.name}
                class="w-full aspect-[16/10] object-cover rounded-2xl shadow-xl"
                loading="eager"
                width="800" height="500"
              />
            ) : (
              <div class="w-full aspect-[16/10] bg-brand-800/50 rounded-2xl flex items-center justify-center text-white/30">Photo pending</div>
            )}
          </div>

          {/* Hero content */}
          <div class="text-white">
            <p class="text-accent font-semibold tracking-[0.12em] uppercase text-sm mb-3">{vehicle.year} &middot; {vehicle.make}</p>
            <h1 class="text-3xl sm:text-4xl lg:text-5xl font-bold tracking-tight">{vehicle.name}</h1>
            <p class="mt-3 text-lg text-white/70 leading-relaxed">{vehicle.tagline_en}</p>

            {/* Key specs */}
            <div class="mt-6 flex flex-wrap gap-3">
              <span class="inline-flex items-center gap-1.5 px-4 py-2 rounded-full bg-white/10 text-sm">
                &#128103; {vehicle.passenger_capacity} {vehicle.passenger_capacity === 1 ? "seat" : "seats"}
              </span>
              <span class="inline-flex items-center gap-1.5 px-4 py-2 rounded-full bg-white/10 text-sm">
                &#128718; {luggageLabel} luggage
              </span>
              <span class="inline-flex items-center gap-1.5 px-4 py-2 rounded-full bg-white/10 text-sm">
                {getFuelLabel(vehicle.fuel_type, "en")}
              </span>
            </div>

            {/* CTA */}
            <div class="mt-8 flex flex-col sm:flex-row gap-3">
              {vehicle.book_path ? (
                <a href={vehicle.book_path} class="btn btn-light btn-primary-lg">Book on Turo</a>
              ) : (
                <a href="/contact/" class="btn btn-light btn-primary-lg">Inquire Now</a>
              )}
              <a href="/how-it-works/" class="btn px-6 py-4 text-base font-semibold text-white border-2 border-white/30 rounded-lg hover:bg-white/10 transition-all">
                How It Works &rarr;
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>

    {/* Gallery strip */}
    {images.length > 1 && (
      <section class="py-8 bg-brand-50 border-b border-border">
        <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
          <div class="grid grid-cols-3 lg:grid-cols-6 gap-3">
            {images.slice(1, 7).map((src, i) => (
              <img
                src={src}
                alt={`${vehicle.name} view ${i+1}`}
                class="w-full aspect-[4/3] object-cover rounded-lg"
                loading="lazy"
                width="400" height="300"
              />
            ))}
          </div>
        </div>
      </section>
    )}

    {/* Best for */}
    <section class="section bg-white">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
          <div>
            <p class="section-eyebrow">Best For</p>
            <h2 class="section-title">Made for {bestFor[0]?.toLowerCase()}</h2>
            <ul class="mt-6 space-y-3">
              {bestFor.map((item: string) => (
                <li class="flex items-start gap-3">
                  <svg class="w-5 h-5 text-accent mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                  <span class="text-ink-secondary">{item}</span>
                </li>
              ))}
            </ul>
          </div>
          <div class="space-y-6">
            <div class="rounded-2xl bg-brand-50 p-8">
              <h3 class="text-lg font-semibold text-ink">Passenger Comfort</h3>
              <p class="mt-2 text-ink-secondary">Spacious seating for up to {vehicle.passenger_capacity} passengers with ample legroom and climate control.</p>
            </div>
            <div class="rounded-2xl bg-brand-50 p-8">
              <h3 class="text-lg font-semibold text-ink">Luggage Capacity</h3>
              <p class="mt-2 text-ink-secondary">Accommodates {vehicle.luggage_large || "multiple"} large and {vehicle.luggage_small || ""} small suitcases — plenty of room for airport travel.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    {/* Specs & Fuel */}
    <section class="section bg-brand-50">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <h2 class="text-3xl font-bold text-ink mb-8">Specifications</h2>
        <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-4">
          {[
            { label: "Year", value: vehicle.year },
            { label: "Make", value: vehicle.make },
            { label: "Model", value: vehicle.model },
            { label: "Fuel", value: getFuelLabel(vehicle.fuel_type, "en") },
            { label: "Seats", value: vehicle.passenger_capacity },
            { label: "Luggage", value: `${vehicle.luggage_large || "-"} large` },
          ].filter(s => s.value).map(spec => (
            <div class="bg-white rounded-xl p-6 text-center">
              <p class="text-2xl font-bold text-ink">{spec.value}</p>
              <p class="text-xs text-ink-tertiary uppercase tracking-wider mt-1">{spec.label}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    {/* Airport Pickup */}
    <section class="section bg-white">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <h2 class="text-3xl font-bold text-ink text-center mb-3">Airport Pickup</h2>
        <p class="text-center text-ink-secondary max-w-xl mx-auto mb-10">
          Pick up your {vehicle.name} at MIA, FLL, or PBI. Contactless handoff from designated airport parking — exact location sent privately.
        </p>
        <div class="grid grid-cols-1 gap-4 sm:grid-cols-3">
          {["MIA", "FLL", "PBI"].map(code => (
            <a href={`/locations/${code === "MIA" ? "miami-international-airport" : code === "FLL" ? "fort-lauderdale-airport" : "palm-beach-airport"}/`}
               class="card card-padded text-center group">
              <div class="text-3xl font-bold text-accent mb-2">{code}</div>
              <p class="text-sm text-ink-secondary">Contactless pickup available</p>
              <span class="mt-3 inline-block text-xs font-medium text-accent group-hover:gap-1.5 transition-all">Details &rarr;</span>
            </a>
          ))}
        </div>
        <p class="mt-4 text-xs text-ink-tertiary text-center">Airport parking charges are the renter's responsibility — disclosed in reservation terms.</p>
      </div>
    </section>

    {/* Related Vehicles */}
    {relatedVehicles.length > 0 && (
      <section class="section bg-brand-50">
        <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
          <h2 class="text-3xl font-bold text-ink text-center">Related Vehicles</h2>
          <div class="mt-8 grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
            {relatedVehicles.map(rv => (
              <a href={`/vehicles/${rv.slug}/`} class="card group">
                <div class="aspect-[16/10] bg-brand-100 overflow-hidden">
                  {rv.hero_image ? (
                    <img src={rv.hero_image} alt={rv.name} class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-[1.04]" loading="lazy" width="600" height="375" />
                  ) : (
                    <div class="w-full h-full flex items-center justify-center text-ink-tertiary text-sm">Photo pending</div>
                  )}
                </div>
                <div class="p-5">
                  <h3 class="font-semibold text-ink group-hover:text-brand transition-colors">{rv.name}</h3>
                  <div class="mt-2 flex gap-2"><span class="chip text-xs">{rv.passenger_capacity} seats</span><span class="chip text-xs">{getFuelLabel(rv.fuel_type, "en")}</span></div>
                </div>
              </a>
            ))}
          </div>
        </div>
      </section>
    )}

    {/* Final CTA */}
    <section class="section gradient-brand text-white text-center">
      <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
        <h2 class="text-4xl font-bold tracking-tight">Ready to drive the {vehicle.name}?</h2>
        <div class="mt-6">
          <a href="/vehicles/" class="btn btn-light btn-primary-lg">View Fleet</a>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>