---
// Logo Direction B — "Highway 305"
// "305" set in bold navy with a horizontal highway-line motif
// running through the numbers. "FLEET" sits to the right in a
// lighter weight. Compact and modern.
---

<svg viewBox="0 0 280 64" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="305 Fleet logo, direction B">
  <!-- 305 with highway lines -->
  <text x="0" y="44" font-family="Manrope, system-ui, sans-serif"
        font-size="40" font-weight="800" fill="#0B1F33" letter-spacing="-2">305</text>

  <!-- Highway dash motif through the 305 -->
  <line x1="2" y1="34" x2="18" y2="34" stroke="#1769D2" stroke-width="2" stroke-dasharray="4 3"/>
  <line x1="22" y1="34" x2="38" y2="34" stroke="#1769D2" stroke-width="2" stroke-dasharray="4 3"/>
  <line x1="42" y1="34" x2="58" y2="34" stroke="#1769D2" stroke-width="2" stroke-dasharray="4 3"/>

  <!-- FLEET text -->
  <text x="74" y="42" font-family="Manrope, system-ui, sans-serif"
        font-size="22" font-weight="600" fill="#0B1F33" letter-spacing="1">FLEET</text>

  <!-- Small coral dot as accent -->
  <circle cx="74" cy="46" r="2.5" fill="#F25C3D"/>
</svg>
