---
// Logo Direction A — "Route 305"
// A clean horizontal lockup with a route-marker "305" badge
// and "FLEET" in a strong sans-serif. The badge uses a subtle
// road-shield shape with a directional arrow.
---

<svg viewBox="0 0 280 64" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="305 Fleet logo, direction A">
  <!-- Route shield badge -->
  <svg x="0" y="4" width="56" height="56" viewBox="0 0 56 56">
    <!-- Shield outline -->
    <path d="M28 4 L48 12 L48 30 C48 42 38 50 28 54 C18 50 8 42 8 30 L8 12 Z"
          fill="#0B1F33" stroke="none"/>
    <!-- Inner shield -->
    <path d="M28 8 L44 14 L44 30 C44 40 36 46 28 50 C20 46 12 40 12 30 L12 14 Z"
          fill="none" stroke="#1769D2" stroke-width="1.5" opacity="0.4"/>
    <!-- 305 text -->
    <text x="28" y="36" text-anchor="middle" font-family="Manrope, system-ui, sans-serif"
          font-size="18" font-weight="800" fill="#FFFFFF" letter-spacing="-1">305</text>
    <!-- Directional arrow -->
    <path d="M28 42 L33 47 L28 52 L23 47 Z" fill="#F25C3D"/>
  </svg>

  <!-- FLEET text -->
  <text x="68" y="42" font-family="Manrope, system-ui, sans-serif"
        font-size="26" font-weight="700" fill="#0B1F33" letter-spacing="-0.5">FLEET</text>

  <!-- Optional tagline space (not rendered) -->
</svg>
