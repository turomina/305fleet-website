---
// Logo Direction C — "305 Mark"
// A compact circular "305" mark on the left, with "305FLEET" as
// a single wordmark to the right. The circle uses a subtle
// directional notch at the top-right suggesting forward movement.
---

<svg viewBox="0 0 280 64" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="305 Fleet logo, direction C">
  <!-- Circular mark -->
  <svg x="2" y="6" width="52" height="52" viewBox="0 0 52 52">
    <!-- Circle body -->
    <circle cx="26" cy="26" r="24" fill="#0B1F33"/>
    <!-- Directional notch -->
    <path d="M40 12 L46 6 L44 18 Z" fill="#0B1F33"/>
    <!-- Inner accent ring -->
    <circle cx="26" cy="26" r="20" fill="none" stroke="#1769D2" stroke-width="1" opacity="0.3"/>
    <!-- 305 text -->
    <text x="26" y="33" text-anchor="middle" font-family="Manrope, system-ui, sans-serif"
          font-size="17" font-weight="800" fill="#FFFFFF" letter-spacing="-0.5">305</text>
  </svg>

  <!-- Wordmark: 305FLEET -->
  <text x="64" y="42" font-family="Manrope, system-ui, sans-serif"
        font-size="24" font-weight="700" fill="#0B1F33" letter-spacing="-0.5">
    <tspan font-weight="800">305</tspan><tspan font-weight="500">Fleet</tspan>
  </text>

  <!-- Coral underline accent -->
  <rect x="64" y="46" width="48" height="2" fill="#F25C3D" rx="1"/>
</svg>
