---
import { SITE, NAV } from "../../config/site";
import LanguageSwitcher from "./LanguageSwitcher.astro";
const year = new Date().getFullYear();
---

<footer class="bg-brand-dark text-white">
  <div class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8 lg:py-16">
    <div class="grid grid-cols-1 gap-8 sm:grid-cols-2 lg:grid-cols-5">
      <!-- Logo + tagline -->
      <div class="lg:col-span-1">
        <img
          src="/images/brand/footer-logo.png"
          alt={`${SITE.name}`}
          width="120"
          height="36"
          class="h-8 w-auto mb-3 brightness-0 invert"
        />
        <p class="text-sm text-gray-300 max-w-xs">
          {SITE.tagline} — {SITE.description}
        </p>
        <div class="mt-4">
          <LanguageSwitcher />
        </div>
      </div>

      <!-- Rentals -->
      <div>
        <h3 class="text-sm font-semibold text-white uppercase tracking-wider mb-4">Rentals</h3>
        <ul class="space-y-2 text-sm">
          {NAV.footer.rentals.map((item) => (
            <li><a href={item.href} class="text-gray-300 hover:text-white">{item.label}</a></li>
          ))}
        </ul>
      </div>

      <!-- Locations -->
      <div>
        <h3 class="text-sm font-semibold text-white uppercase tracking-wider mb-4">Locations</h3>
        <ul class="space-y-2 text-sm">
          {NAV.footer.locations.map((item) => (
            <li><a href={item.href} class="text-gray-300 hover:text-white">{item.label}</a></li>
          ))}
        </ul>
      </div>

      <!-- Info -->
      <div>
        <h3 class="text-sm font-semibold text-white uppercase tracking-wider mb-4">Info</h3>
        <ul class="space-y-2 text-sm">
          {NAV.footer.info.map((item) => (
            <li><a href={item.href} class="text-gray-300 hover:text-white">{item.label}</a></li>
          ))}
        </ul>
      </div>

      <!-- Support -->
      <div>
        <h3 class="text-sm font-semibold text-white uppercase tracking-wider mb-4">Support</h3>
        <ul class="space-y-2 text-sm">
          {NAV.footer.support.map((item) => (
            <li><a href={item.href} class="text-gray-300 hover:text-white">{item.label}</a></li>
          ))}
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="mt-12 pt-8 border-t border-white/10 flex flex-col sm:flex-row justify-between items-center gap-4">
      <p class="text-xs text-gray-400">
        &copy; {year} {SITE.legalName}. All rights reserved.
      </p>
      <div class="flex items-center gap-4 text-xs">
        {NAV.legal.map((item) => (
          <a href={item.href} class="text-gray-400 hover:text-white">{item.label}</a>
        ))}
      </div>
    </div>
  </div>
</footer>