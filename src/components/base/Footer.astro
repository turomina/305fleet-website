---
import { SITE } from "../../config/site";
import LanguageSwitcher from "./LanguageSwitcher.astro";
const year = new Date().getFullYear();
---

<footer class="bg-brand-dark text-white">
  <div class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8 lg:py-16">
    <div class="grid grid-cols-1 gap-8 sm:grid-cols-2 lg:grid-cols-4">
      <!-- Logo + tagline -->
      <div class="lg:col-span-1">
        <img
          src="/images/brand/footer-logo.png"
          alt={`${SITE.name}`}
          width="120"
          height="36"
          class="h-8 w-auto mb-3 brightness-0 invert"
        />
        <p class="text-sm text-gray-300 max-w-xs">
          {SITE.tagline} — {SITE.description}
        </p>
        <div class="mt-4 flex gap-3">
          {SITE.phone ? (
            <a
              href={`tel:${SITE.phone}`}
              class="text-gray-300 hover:text-white"
              aria-label="Call us"
            >
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
            </a>
          ) : (
            <span class="text-gray-500" aria-label="Phone number coming soon">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
            </span>
          )}
          {SITE.whatsapp ? (
            <a
              href={`https://wa.me/${SITE.whatsapp}`}
              class="text-gray-300 hover:text-white"
              aria-label="WhatsApp"
            >
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.148-.669-1.611-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893A11.821 11.821 0 0020.885 3.488" />
              </svg>
            </a>
          ) : (
            <span class="text-gray-500" aria-label="WhatsApp coming soon">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.148-.669-1.611-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893A11.821 11.821 0 0020.885 3.488" />
              </svg>
            </span>
          )}
        </div>
      </div>

      <!-- Vehicles + Rental Options -->
      <div>
        <h3 class="text-sm font-semibold text-white uppercase tracking-wider mb-4">Rentals</h3>
        <ul class="space-y-2 text-sm">
          <li><a href="/vehicles/" class="text-gray-300 hover:text-white">Vehicles</a></li>
          <li><a href="/rental-options/daily/" class="text-gray-300 hover:text-white">Daily Rentals</a></li>
          <li><a href="/rental-options/weekly/" class="text-gray-300 hover:text-white">Weekly Rentals</a></li>
          <li><a href="/rental-options/monthly/" class="text-gray-300 hover:text-white">Monthly Rentals</a></li>
          <li><a href="/rental-options/business-corporate/" class="text-gray-300 hover:text-white">Business & Corporate</a></li>
          <li><a href="/deals/" class="text-gray-300 hover:text-white">Deals</a></li>
        </ul>
      </div>

      <!-- Locations -->
      <div>
        <h3 class="text-sm font-semibold text-white uppercase tracking-wider mb-4">Locations</h3>
        <ul class="space-y-2 text-sm">
          <li><a href="/locations/miami-international-airport/" class="text-gray-300 hover:text-white">Miami International (MIA)</a></li>
          <li><a href="/locations/fort-lauderdale-airport/" class="text-gray-300 hover:text-white">Fort Lauderdale (FLL)</a></li>
          <li><a href="/locations/palm-beach-airport/" class="text-gray-300 hover:text-white">Palm Beach (PBI)</a></li>
          <li><a href="/how-it-works/" class="text-gray-300 hover:text-white">How It Works</a></li>
          <li><a href="/reviews/" class="text-gray-300 hover:text-white">Reviews</a></li>
        </ul>
      </div>

      <!-- Support -->
      <div>
        <h3 class="text-sm font-semibold text-white uppercase tracking-wider mb-4">Support</h3>
        <ul class="space-y-2 text-sm">
          <li><a href="/contact/" class="text-gray-300 hover:text-white">Contact</a></li>
          <li><a href="/faq/" class="text-gray-300 hover:text-white">FAQ</a></li>
          <li><a href="/support/" class="text-gray-300 hover:text-white">Support</a></li>
          <li><a href="/about/" class="text-gray-300 hover:text-white">About 305 Fleet</a></li>
          <li><a href="/rental-requirements/" class="text-gray-300 hover:text-white">Requirements</a></li>
          <li><a href="/rental-policies/" class="text-gray-300 hover:text-white">Policies</a></li>
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="mt-12 pt-8 border-t border-white/10 flex flex-col sm:flex-row justify-between items-center gap-4">
      <p class="text-xs text-gray-400">
        &copy; {year} {SITE.legalName}. All rights reserved.
      </p>
      <div class="flex items-center gap-4 text-xs">
        <a href="/privacy/" class="text-gray-400 hover:text-white">Privacy</a>
        <a href="/terms/" class="text-gray-400 hover:text-white">Terms</a>
        <a href="/accessibility/" class="text-gray-400 hover:text-white">Accessibility</a>
        <LanguageSwitcher />
      </div>
    </div>
  </div>
</footer>