---
// Reusable Process Step component for How It Works
export interface Props {
  number: string;
  title: string;
  description: string;
  icon?: string; // SVG path data
  isLast?: boolean;
}
const { number, title, description, icon, isLast = false } = Astro.props;
---

<div class="relative flex flex-col items-center text-center">
  <!-- Step number circle with icon -->
  <div class="relative z-10 flex h-14 w-14 items-center justify-center rounded-full bg-navy-900 text-white shadow-md">
    {icon ? (
      <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d={icon} />
      </svg>
    ) : (
      <span class="text-lg font-bold">{number}</span>
    )}
  </div>

  <!-- Connector line (desktop only) -->
  {!isLast && (
    <div class="hidden md:block absolute top-7 left-1/2 w-full h-0.5 bg-border" style="transform: translateX(50%);"></div>
  )}

  <!-- Content -->
  <h3 class="mt-4 text-lg font-semibold text-navy-900">{title}</h3>
  <p class="mt-2 text-sm text-ink-secondary leading-relaxed max-w-xs">{description}</p>
</div>
