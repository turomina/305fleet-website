---
// Reusable Vehicle Card component
import { getFuelLabel } from "../../config/labels";
export interface Props {
  vehicle: any;
  locale?: "en" | "es";
}
const { vehicle: v, locale = "en" } = Astro.props;
const isEs = locale === "es";
const previewLabel = isEs ? "Vista previa" : "Preview";
const detailsLabel = isEs ? "Detalles" : "Details";
---

<a
  href={`/vehicles/${v.slug}/`}
  class="group block overflow-hidden rounded-xl border border-border bg-surface shadow-xs transition-all hover:border-navy-300 hover:shadow-md"
>
  <div class="aspect-[4/3] bg-surface-light flex items-center justify-center overflow-hidden">
    {v.hero_image ? (
      <img
        src={v.hero_image}
        alt={v.name}
        class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-[1.03]"
        width="600"
        height="450"
        loading="lazy"
      />
    ) : (
      <div class="text-center p-8">
        <p class="text-ink-tertiary text-sm">{isEs ? "Foto pendiente" : "Photo pending"}</p>
      </div>
    )}
  </div>
  <div class="p-5">
    <h3 class="text-lg font-semibold text-navy-900 group-hover:text-blue-500 transition-colors">{v.name}</h3>
    <p class="text-sm text-ink-secondary mt-1 line-clamp-1">
      {isEs ? v.tagline_es || v.tagline_en : v.tagline_en}
    </p>
    <div class="mt-3 flex items-center gap-4 text-sm text-ink-secondary">
      <span class="flex items-center gap-1">
        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a4 4 0 00-3-3.87M9 20H4v-2a4 4 0 013-3.87m6-5.13a4 4 0 11-8 0 4 4 0 018 0zm6 0a4 4 0 11-8 0 4 4 0 018 0z" /></svg>
        {v.passenger_capacity}
      </span>
      <span class="flex items-center gap-1">
        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" /></svg>
        {v.luggage_large}
      </span>
      <span>{getFuelLabel(v.fuel_type, locale)}</span>
    </div>
    {v.publication_status === "preview_only" && (
      <div class="mt-2">
        <span class="inline-block rounded-full bg-warning-light px-2.5 py-0.5 text-xs font-medium text-warning">
          {previewLabel}
        </span>
      </div>
    )}
    <div class="mt-4 flex items-center justify-between">
      <span class="text-lg font-semibold text-navy-700">
        {v.price_display_daily
          ? `$${v.price_display_daily}/${isEs ? "día" : "day"}`
          : (isEs ? "Precio por confirmar" : "Pricing TBD")}
      </span>
      <span class="text-sm font-medium text-blue-500 group-hover:underline">
        {detailsLabel} →
      </span>
    </div>
  </div>
</a>
