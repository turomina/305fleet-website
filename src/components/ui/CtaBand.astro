---
// Reusable CTA Band component
export interface Props {
  title: string;
  subtitle?: string;
  primaryHref?: string;
  primaryLabel?: string;
  secondaryHref?: string;
  secondaryLabel?: string;
}
const {
  title,
  subtitle,
  primaryHref = "/vehicles/",
  primaryLabel = "Browse Vehicles",
  secondaryHref = "/contact/",
  secondaryLabel = "Contact Us",
} = Astro.props;
---

<section class="bg-navy-900 text-white py-16 lg:py-20">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 text-center">
    <h2 class="text-3xl font-bold sm:text-4xl tracking-tight">{title}</h2>
    {subtitle && <p class="mt-3 text-lg text-navy-100">{subtitle}</p>}
    <div class="mt-8 flex flex-col sm:flex-row justify-center gap-4">
      <a
        href={primaryHref}
        class="inline-flex items-center justify-center rounded-lg bg-white px-8 py-4 text-base font-semibold text-navy-900 shadow-md transition-colors hover:bg-surface-light"
      >
        {primaryLabel}
      </a>
      <a
        href={secondaryHref}
        class="inline-flex items-center justify-center rounded-lg border-2 border-white/30 px-8 py-4 text-base font-semibold text-white transition-colors hover:bg-white/10"
      >
        {secondaryLabel}
      </a>
    </div>
  </div>
</section>
