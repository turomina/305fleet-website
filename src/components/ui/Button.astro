---
// Reusable Button component
export interface Props {
  variant?: "primary" | "secondary" | "ghost" | "outline";
  size?: "sm" | "md" | "lg";
  href?: string;
  type?: "button" | "submit";
  class?: string;
}
const {
  variant = "primary",
  size = "md",
  href,
  type = "button",
  class: className = "",
} = Astro.props;

const base = "inline-flex items-center justify-center font-semibold rounded-lg transition-all duration-200 focus-visible:outline-2 focus-visible:outline-blue-500 focus-visible:outline-offset-2";

const variants = {
  primary: "bg-navy-900 text-white hover:bg-navy-700 shadow-sm",
  secondary: "bg-blue-500 text-white hover:bg-blue-600 shadow-sm",
  ghost: "text-navy-700 hover:bg-navy-50",
  outline: "border-2 border-navy-900 text-navy-900 hover:bg-navy-900 hover:text-white",
};

const sizes = {
  sm: "h-9 px-4 text-sm",
  md: "h-11 px-6 text-sm",
  lg: "h-13 px-8 text-base",
};

const classes = `${base} ${variants[variant]} ${sizes[size]} ${className}`;
---

{href ? (
  <a href={href} class={classes}>
    <slot />
  </a>
) : (
  <button type={type} class={classes}>
    <slot />
  </button>
)}
