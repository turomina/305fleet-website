# Cloudflare Pages environment variables
# Set these in the Cloudflare Pages dashboard (Settings → Environment variables)
# or in .dev.vars for local development (NEVER COMMIT .dev.vars)

# Production
# CLOUDFLARE_ACCOUNT_ID=...
# AIRTABLE_PAT=op://...
# AIRTABLE_BASE_ID=op://...

# For booking phase (future)
# WHEELBASE_API_KEY=op://...
# WHEELBASE_DEALER_ID=op://...

# .cf-secrets.env (for wrangler deploy — NEVER COMMIT)
# CLOUDFLARE_API_TOKEN=op://...
# CLOUDFLARE_ACCOUNT_ID=da8cf249fee1f72b4364f153c05f19b9