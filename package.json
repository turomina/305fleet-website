{
  "name": "305fleet-website",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "astro dev --host",
    "build": "astro build",
    "preview": "astro preview --host",
    "check": "astro check",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "deploy:preview": "op run --env-file .cf-secrets.env -- wrangler pages deploy dist --project-name=305fleet-website --branch=preview",
    "deploy:prod": "op run --env-file .cf-secrets.env -- wrangler pages deploy dist --project-name=305fleet-website"
  },
  "dependencies": {
    "@astrojs/mdx": "^7.0.0",
    "@astrojs/sitemap": "^3.7.3",
    "astro": "^7.0.3",
    "sharp": "^0.35.2"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@tailwindcss/vite": "^4.0.0",
    "tailwindcss": "^4.0.0",
    "prettier": "^3.0.0",
    "prettier-plugin-astro": "^0.14.1",
    "typescript": "^5.6.0",
    "wrangler": "^4.105.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}